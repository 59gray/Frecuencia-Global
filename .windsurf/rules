# =============================================================================
# COMANDOS PROHIBIDOS
# =============================================================================

# Comandos que NUNCA deben ejecutarse:
forbidden_commands:
  - pattern: "cat.*\\.env"
    reason: "Exposición de credenciales"
  - pattern: "type.*\\.env"
    reason: "Exposición de credenciales en Windows"
  - pattern: "Get-Content.*\\.env"
    reason: "Exposición de credenciales en PowerShell"
  - pattern: "docker.*up.*n8n"
    reason: "Inicio de servicios requiere autorización explícita"
  - pattern: "wrangler deploy"
    reason: "Deploy a producción requiere autorización explícita"
  - pattern: "npm run deploy"
    reason: "Deploy a producción requiere autorización explícita"
  - pattern: "python.*publish"
    reason: "Publicación automatizada prohibida"
  - pattern: "publish_dispatch"
    reason: "Scripts de publicación requieren autorización"
  - pattern: "notion.*import.*token"
    reason: "Importación con tokens requiere autorización"

# =============================================================================
# COMANDOS READ-ONLY PERMITIDOS
# =============================================================================

# Comandos seguros para exploración SIN modificación:
allowed_readonly_commands:
  - pattern: "Get-ChildItem.*-Force"
    purpose: "Listar archivos ocultos y directorios"
  - pattern: "Test-Path"
    purpose: "Verificar existencia de archivos"
  - pattern: "Select-Object.*Name.*LastWriteTime"
    purpose: "Obtener metadata sin contenido"
  - pattern: "Get-FileHash.*SHA256"
    purpose: "Calcular hashes para verificación"
  - pattern: "git status"
    purpose: "Verificar estado de repositorio"
  - pattern: "git log.*-n"
    purpose: "Ver historial limitado"
  - pattern: "findstr /s /i"
    purpose: "Búsqueda de strings en múltiples archivos"
  - pattern: "Get-Content.*\.json"
    condition: "SIN contener secretos en el path"
  - pattern: "Get-Content.*\.md"
    condition: "Documentación pública"
  - pattern: "Get-Content.*\.mjs"
    condition: "Configuración build"
  - pattern: "Get-Content.*\.toml"
    condition: "Configuración build"

# =============================================================================
# REGLA DE BACKUP ANTES DE EDITAR
# =============================================================================

# Obligatorio para archivos en carpetas NO versionadas (no hay .git):
backup_rule:
  condition: "NOT git_repo AND file_modified_by_agent"
  required_actions:
    - "Verificar existencia de .backups/ en directorio padre"
    - "Copiar archivo original a .backups/{filename}_{timestamp}.bak"
    - "Registrar en BACKUP_MANIFEST_{fecha}.txt: fecha, archivo, hash SHA256"
    - "Solo entonces proceder con edición"
  
  git_repo_check: |
    # PowerShell
    Test-Path "C:\Users\farid\Documents\Frecuencia Global\.git" -PathType Container
    # Resultado: False (NO es repo Git)
    # Por tanto: SIEMPRE backup antes de editar

