# Archivos y patrones NUNCA a los que NUNCA acceder, leer, copiar ni modificar:
denylist:
  files:
    - "08_n8n/.env"
    - "**/.env"
    - "**/secrets.json"
    - "**/credentials.json"
    - "**/*token*"
    - "**/*key*"
    - "**/cookies.txt"
    - "**/session*"
  
  directories:
    - ".chrome-gemini-stable"
    - ".chrome-ig-stable"
    - ".chrome-linkedin-stable"
