# =============================================================================
# NOTION API - Configuración de Bases de Datos
# =============================================================================
# Fuente: NOTION_FIELD_MAP.json (líneas 240-241, 336, 372, 423)
# NOTION_TOKEN debe tener acceso a las bases de datos listadas abajo

# Token de integración Notion (Internal Integration Token)
# NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base de datos: PIEZAS (pieces)
# NOTION_DB_PIECES_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DB_PIEZAS_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # alias alternativo

# Base de datos: FUENTES (fuentes)
# NOTION_DB_FUENTES_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base de datos: ASSETS (assets)
# NOTION_DB_ASSETS_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base de datos: INCIDENCIAS / BLOCKERS (incidencias)
# NOTION_DB_INCIDENCIAS_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

