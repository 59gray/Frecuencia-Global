---
interface Props {
  color?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { color = 'var(--color-fg-cyan)', size = 'md' } = Astro.props;

const sizeMap = { sm: 'w-2 h-2', md: 'w-3 h-3', lg: 'w-4 h-4' };
const glowMap = { sm: '2px', md: '4px', lg: '6px' };
---

<span
  class:list={['inline-block rounded-full', sizeMap[size]]}
  style={`background: ${color}; box-shadow: 0 0 ${glowMap[size]} ${color};`}
  role="presentation"
></span>
