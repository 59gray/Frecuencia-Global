---
interface Props {
  action?: string;
}

const { action } = Astro.props;
const configuredAction = action ?? import.meta.env.PUBLIC_FORMSPREE_ENDPOINT ?? '';
const isConfigured = configuredAction.startsWith('https://formspree.io/f/');
---

<form
  method="POST"
  action={isConfigured ? configuredAction : undefined}
  class="fg-tactical-panel fg-corner-cut mx-auto max-w-xl space-y-fg-md p-6 sm:p-7"
>
  <p class="font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray">mensaje directo</p>

  {!isConfigured && (
    <p class="fg-corner-cut border border-white/12 bg-white/5 px-3 py-2 text-sm text-fg-gray">
      Formulario temporalmente no disponible. Usa el correo oficial para contactarnos.
    </p>
  )}

  <div>
    <label for="name" class="mb-fg-2xs block font-data text-xs tracking-widest text-fg-gray">NOMBRE</label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full border border-white/15 bg-fg-surface/55 px-fg-md py-fg-sm font-body text-sm text-fg-white outline-none transition-colors focus:border-fg-cyan"
      placeholder="Tu nombre"
    />
  </div>

  <div>
    <label for="email" class="mb-fg-2xs block font-data text-xs tracking-widest text-fg-gray">EMAIL</label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full border border-white/15 bg-fg-surface/55 px-fg-md py-fg-sm font-body text-sm text-fg-white outline-none transition-colors focus:border-fg-cyan"
      placeholder="tu@email.com"
    />
  </div>

  <div>
    <label for="subject" class="mb-fg-2xs block font-data text-xs tracking-widest text-fg-gray">ASUNTO</label>
    <input
      type="text"
      id="subject"
      name="subject"
      required
      class="w-full border border-white/15 bg-fg-surface/55 px-fg-md py-fg-sm font-body text-sm text-fg-white outline-none transition-colors focus:border-fg-cyan"
      placeholder="¿De qué se trata?"
    />
  </div>

  <div>
    <label for="message" class="mb-fg-2xs block font-data text-xs tracking-widest text-fg-gray">MENSAJE</label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      class="w-full resize-y border border-white/15 bg-fg-surface/55 px-fg-md py-fg-sm font-body text-sm text-fg-white outline-none transition-colors focus:border-fg-cyan"
      placeholder="Tu mensaje..."
    ></textarea>
  </div>

  <!-- Honeypot anti-spam -->
  <div class="hidden" aria-hidden="true">
    <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
  </div>

  <button
    type="submit"
    disabled={!isConfigured}
    aria-disabled={!isConfigured}
    class="fg-corner-cut w-full cursor-pointer border border-fg-cyan bg-fg-cyan/8 px-fg-xl py-fg-sm font-data text-sm tracking-widest text-fg-cyan transition-colors hover:bg-fg-cyan/16 hover:text-fg-white"
  >
    {isConfigured ? 'ENVIAR MENSAJE' : 'FORMULARIO NO DISPONIBLE'}
  </button>
</form>
