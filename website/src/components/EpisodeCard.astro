---
import PillarPill from './PillarPill.astro';

interface PlatformLinks {
  spotify?: string;
  apple?: string;
  youtube?: string;
}

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  pilar: 'p1' | 'p2' | 'p3' | 'p4';
  slug: string;
  coverImage: string;
  duration: string;
  episodeNumber: number;
  season: number;
  videoMode: 'editorial-visualizer' | 'on-camera' | 'hybrid';
  platformLinks?: PlatformLinks;
}

const {
  title,
  description,
  publishDate,
  pilar,
  slug,
  coverImage,
  duration,
  episodeNumber,
  season,
  videoMode,
  platformLinks = {},
} = Astro.props;

const formattedDate = publishDate.toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});

const activePlatforms = [
  platformLinks.spotify ? 'Spotify' : null,
  platformLinks.apple ? 'Apple Podcasts' : null,
  platformLinks.youtube ? 'YouTube' : null,
].filter(Boolean) as string[];

const videoModeLabelMap = {
  'editorial-visualizer': 'Editorial audiovisual',
  'on-camera': 'Conduccion en camara',
  hybrid: 'Formato hibrido',
} as const;

const videoModeLabel = videoModeLabelMap[videoMode];
---

<article class="group fg-tactical-panel fg-corner-cut border-t border-white/15 p-5 pt-6">
  <span class="pointer-events-none absolute right-4 top-3 font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray/45" aria-hidden="true">
    episodio
  </span>

  <a href={`/podcast/${slug}`} class="fg-corner-cut mb-fg-md block aspect-video overflow-hidden border border-white/12 bg-fg-surface/35">
    <img
      src={coverImage}
      alt={title}
      class="h-full w-full object-cover transition-[transform,opacity] duration-300 group-hover:scale-[1.02] group-hover:opacity-95"
      loading="lazy"
    />
  </a>

  <div class="flex flex-wrap items-center justify-between gap-3">
    <PillarPill pilar={pilar} />
    <time class="font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray" datetime={publishDate.toISOString()}>
      {formattedDate}
    </time>
  </div>

  <a href={`/podcast/${slug}`} class="mt-fg-sm block">
    <h3 class="text-xl font-semibold text-fg-white transition-colors duration-300 group-hover:text-fg-cyan sm:text-2xl">
      {title}
    </h3>
  </a>

  <p class="mt-fg-sm text-sm leading-relaxed text-fg-gray">
    {description}
  </p>

  <dl class="mt-4 grid grid-cols-2 gap-3 border-t border-white/12 pt-4 font-data text-[10px] uppercase tracking-[0.22em] text-fg-gray">
    <div>
      <dt>episodio</dt>
      <dd class="mt-1 text-fg-white">S{season} / EP{String(episodeNumber).padStart(2, '0')}</dd>
    </div>
    <div>
      <dt>duración</dt>
      <dd class="mt-1 text-fg-white">{duration}</dd>
    </div>
    <div class="col-span-2">
      <dt>formato</dt>
      <dd class="mt-1 text-fg-white">{videoModeLabel}</dd>
    </div>
    {activePlatforms.length > 0 && (
      <div class="col-span-2">
        <dt>distribución</dt>
        <dd class="mt-1 text-fg-white">{activePlatforms.join(' / ')}</dd>
      </div>
    )}
  </dl>

  <a href={`/podcast/${slug}`} class="mt-4 inline-flex items-center gap-2 font-data text-[10px] uppercase tracking-[0.22em] text-fg-cyan hover:text-fg-white">
    <span>escuchar episodio</span>
    <span aria-hidden="true">→</span>
  </a>
</article>
