---
import PillarPill from './PillarPill.astro';

interface PlatformLinks {
  spotify?: string;
  apple?: string;
  youtube?: string;
}

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  pilar: 'p1' | 'p2' | 'p3' | 'p4';
  slug: string;
  coverImage: string;
  duration: string;
  episodeNumber: number;
  season: number;
  videoMode: 'editorial-visualizer' | 'on-camera' | 'hybrid';
  platformLinks?: PlatformLinks;
}

const {
  title,
  description,
  publishDate,
  pilar,
  slug,
  coverImage,
  duration,
  episodeNumber,
  season,
  videoMode,
  platformLinks = {},
} = Astro.props;

const formattedDate = publishDate.toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});

const activePlatforms = [
  platformLinks.spotify ? 'Spotify' : null,
  platformLinks.apple ? 'Apple Podcasts' : null,
  platformLinks.youtube ? 'YouTube' : null,
].filter(Boolean) as string[];

const videoModeLabel = videoMode === 'editorial-visualizer' ? 'Visualizer editorial' : videoMode;
---

<article class="group border-t border-white/10 pt-md">
  <a href={`/podcast/${slug}`} class="mb-md block aspect-video overflow-hidden border border-white/10 bg-fg-surface/30">
    <img
      src={coverImage}
      alt={title}
      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
      loading="lazy"
    />
  </a>

  <div class="flex flex-wrap items-center justify-between gap-3">
    <PillarPill pilar={pilar} />
    <time class="font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray" datetime={publishDate.toISOString()}>
      {formattedDate}
    </time>
  </div>

  <a href={`/podcast/${slug}`} class="mt-sm block">
    <h3 class="font-display text-2xl leading-[0.9] tracking-[0.05em] text-fg-white transition-colors duration-300 group-hover:text-fg-cyan">
      {title}
    </h3>
  </a>

  <p class="mt-sm text-sm leading-relaxed text-fg-gray">
    {description}
  </p>

  <dl class="mt-4 grid grid-cols-2 gap-3 border-t border-white/10 pt-4 font-data text-[10px] uppercase tracking-[0.22em] text-fg-gray">
    <div>
      <dt>episodio</dt>
      <dd class="mt-1 text-fg-white">S{season} / EP{String(episodeNumber).padStart(2, '0')}</dd>
    </div>
    <div>
      <dt>duración</dt>
      <dd class="mt-1 text-fg-white">{duration}</dd>
    </div>
    <div class="col-span-2">
      <dt>modo video</dt>
      <dd class="mt-1 text-fg-white">{videoModeLabel}</dd>
    </div>
    {activePlatforms.length > 0 && (
      <div class="col-span-2">
        <dt>distribución</dt>
        <dd class="mt-1 text-fg-white">{activePlatforms.join(' / ')}</dd>
      </div>
    )}
  </dl>
</article>
