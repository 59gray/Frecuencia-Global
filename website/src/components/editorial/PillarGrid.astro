---
import SignalNode from '../SignalNode.astro';

interface Pillar {
  id: 'p1' | 'p2' | 'p3' | 'p4';
  number: string;
  title: string;
  subtitle: string;
  href: string;
  description: string;
}

interface Props {
  pillars: Pillar[];
}

const { pillars } = Astro.props;

const pilarColors: Record<string, { border: string; accent: string; text: string; hoverGlow: string }> = {
  p1: {
    border: 'border-pilar-p1/25 hover:border-pilar-p1/55',
    accent: 'bg-pilar-p1',
    text: 'text-pilar-p1',
    hoverGlow: 'hover:shadow-[0_0_24px_-8px_rgba(121,175,191,0.18)]',
  },
  p2: {
    border: 'border-pilar-p2/25 hover:border-pilar-p2/55',
    accent: 'bg-pilar-p2',
    text: 'text-pilar-p2',
    hoverGlow: 'hover:shadow-[0_0_24px_-8px_rgba(124,114,143,0.16)]',
  },
  p3: {
    border: 'border-pilar-p3/25 hover:border-pilar-p3/55',
    accent: 'bg-pilar-p3',
    text: 'text-pilar-p3',
    hoverGlow: 'hover:shadow-[0_0_24px_-8px_rgba(127,143,115,0.16)]',
  },
  p4: {
    border: 'border-pilar-p4/25 hover:border-pilar-p4/55',
    accent: 'bg-pilar-p4',
    text: 'text-pilar-p4',
    hoverGlow: 'hover:shadow-[0_0_20px_-8px_rgba(107,124,163,0.18)]',
  },
};
---

<section class="fg-fallout-matrix relative py-12 lg:py-16 border-b border-white/10">
  <div class="absolute inset-0 signal-grid opacity-[0.025]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-0 opacity-[0.05]" aria-hidden="true">
    <img src="/images/sections/fg-section-close.png" alt="" class="h-full w-full object-cover mix-blend-soft-light" loading="lazy" decoding="async" />
  </div>
  <div class="relative mx-auto max-w-[1400px] px-6 lg:px-12">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-8 pb-5 border-b border-white/10">
      <div class="flex items-center gap-4">
        <SignalNode size="md" />
        <div>
          <p class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-cyan">Sistema editorial</p>
          <h2 class="mt-1 font-display text-3xl text-fg-white sm:text-4xl tracking-wide">Cuatro frecuencias</h2>
        </div>
      </div>
      <p class="font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray/80 max-w-xl text-left sm:text-right leading-relaxed">
        Misma señal, cuatro lecturas: cada pilar tiene su promesa — no son etiquetas intercambiables.
      </p>
    </div>

    <div class="grid gap-4 sm:gap-5 md:grid-cols-2 lg:grid-cols-4 lg:gap-4">
      {pillars.map((pillar) => {
        const colors = pilarColors[pillar.id];
        return (
          <a
            href={pillar.href}
            class:list={[
              'group relative flex flex-col border bg-black/25 p-5 pt-6 transition-all duration-300',
              'hover:bg-white/[0.03] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-fg-cyan',
              colors.border,
              colors.hoverGlow,
            ]}
          >
            <span
              class:list={[
                'pointer-events-none absolute left-4 top-0 hidden font-data text-[10px] uppercase tracking-[0.35em] opacity-40 select-none sm:inline',
                colors.text,
              ]}
              aria-hidden="true"
            >
              [
            </span>
            <span
              class:list={[
                'pointer-events-none absolute right-4 top-0 hidden font-data text-[10px] uppercase tracking-[0.35em] opacity-40 select-none sm:inline',
                colors.text,
              ]}
              aria-hidden="true"
            >
              ]
            </span>

            <div class:list={['absolute top-0 left-0 right-0 h-0.5', colors.accent, 'opacity-70']}></div>

            <div class="flex items-center justify-between mb-4 mt-1">
              <span class:list={['font-data text-2xl sm:text-3xl tabular-nums', colors.text, 'opacity-90']}>
                {pillar.number}
              </span>
              <span class="font-data text-xs text-fg-gray/50 transition-transform duration-300 group-hover:translate-x-0.5">
                →
              </span>
            </div>

            <h3 class="font-display text-lg sm:text-xl tracking-wide text-fg-white mb-1">{pillar.title}</h3>
            <p class:list={['text-xs sm:text-sm font-medium mb-2', colors.text]}>{pillar.subtitle}</p>
            <p class="text-sm leading-snug text-fg-gray/90 flex-1">{pillar.description}</p>
          </a>
        );
      })}
    </div>
  </div>
</section>
