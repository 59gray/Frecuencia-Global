---
import SignalNode from '../SignalNode.astro';
import PillarPill from '../PillarPill.astro';

interface Props {
  kicker?: string;
  tagline?: string;
  title: string;
  subtitle: string;
  featured?: {
    title: string;
    pilar: 'p1' | 'p2' | 'p3' | 'p4';
    href: string;
    image?: string;
    description?: string;
  };
  ctas?: {
    primary: { label: string; href: string };
    secondary?: { label: string; href: string };
  };
}

const {
  kicker = 'Medio editorial',
  tagline = 'Análisis internacional con pulso electrónico.',
  title,
  subtitle,
  featured,
  ctas,
} = Astro.props;
---

<section class="relative overflow-hidden border-b border-cyan-500/15 fg-hud-chrome">
  <!-- Capa A: atmósfera raster (pipeline FG v5 — densidad editorial, no placeholder) -->
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src="/images/hero/fg-hero-atmosphere-grid.png"
      alt=""
      class="h-full w-full scale-[1.02] object-cover opacity-[0.48]"
      loading="eager"
      decoding="async"
    />
  </div>
  <div class="pointer-events-none absolute inset-0 mix-blend-screen opacity-[0.32]" aria-hidden="true">
    <img src="/images/hero/fg-hero-atmosphere-cyan.png" alt="" class="h-full w-full object-cover" loading="eager" />
  </div>
  <div class="pointer-events-none absolute inset-0 mix-blend-soft-light opacity-[0.14]" aria-hidden="true">
    <img src="/images/hero/fg-hero-atmosphere-frame.png" alt="" class="h-full w-full object-cover" loading="eager" />
  </div>

  <!-- Capa B: sistema vectorial — rutas, nodos, bandas de escaneo -->
  <div class="absolute inset-0 opacity-[0.82]" aria-hidden="true">
    <img
      src="/images/system/fg-overlay-hero-master.svg"
      alt=""
      class="fg-hero-scan-img h-full w-full object-cover object-center"
      loading="eager"
    />
  </div>

  <!-- Capa C: rejilla + lectura de profundidad -->
  <div class="signal-grid absolute inset-0 opacity-[0.065]" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_75%_55%_at_50%_-25%,rgba(121,175,191,0.1),transparent_58%),radial-gradient(ellipse_45%_35%_at_100%_0%,rgba(143,133,115,0.08),transparent_52%),radial-gradient(ellipse_35%_25%_at_0%_15%,rgba(124,114,143,0.05),transparent_45%),linear-gradient(180deg,rgba(6,8,12,0.15),rgba(6,8,12,0.94))]"
    aria-hidden="true"
  ></div>

  <!-- Línea de barrido (CSS, respeta prefers-reduced-motion en global.css) -->
  <div class="fg-hero-scanline pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-[1200px] px-5 sm:px-8 lg:px-12">
    <div class="pt-6 pb-1 sm:pt-9 sm:pb-2 lg:pt-11 lg:pb-3">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between sm:gap-8">
        <div class="min-w-0 flex-1">
          <div class="mb-3 flex items-center gap-2">
            <SignalNode size="sm" />
            <span class="font-data text-[10px] uppercase tracking-[0.22em] text-fg-gray/90 sm:text-[11px]">
              {kicker}
            </span>
          </div>

          <p
            class="mb-3 max-w-prose bg-gradient-to-r from-fg-cyan via-fg-white to-fg-phosphor bg-clip-text font-data text-[11px] uppercase tracking-[0.24em] text-transparent sm:text-xs"
          >
            {tagline}
          </p>

          <!-- Marca de estado en mobile: mantiene atmósfera sin repetir nombre de marca -->
          <div class="mb-3 sm:hidden">
            <span class="inline-flex items-center gap-2 border border-fg-cyan/45 bg-black/35 px-2.5 py-1 font-data text-[10px] uppercase tracking-[0.24em] text-fg-cyan">
              <span class="h-1.5 w-1.5 rounded-full bg-fg-cyan animate-pulse"></span>
              Señal activa
            </span>
          </div>

          <div class="mb-4 flex flex-col sm:mb-5 sm:flex-row sm:items-end sm:gap-6">
            <h1
              class="font-display max-w-[18ch] break-words text-[2.35rem] leading-[0.98] tracking-tight text-fg-white sm:text-4xl md:text-5xl lg:text-6xl"
            >
              {title}
            </h1>
            <div class="mt-3 hidden shrink-0 sm:block">
              <span class="inline-flex items-center gap-2 border border-fg-phosphor/35 bg-black/35 px-3 py-1.5 font-data text-[10px] uppercase tracking-[0.24em] text-fg-phosphor">
                <span class="h-1.5 w-1.5 rounded-full bg-fg-cyan animate-pulse"></span>
                Señal activa
              </span>
            </div>
          </div>

          <p
            class="max-w-2xl text-base leading-relaxed text-fg-gray/95 sm:text-[1.05rem] lg:max-w-3xl lg:text-xl line-clamp-3 sm:line-clamp-none"
          >
            {subtitle}
          </p>
        </div>
      </div>

      {(ctas?.primary || ctas?.secondary) && (
        <div class="mt-5 flex flex-wrap gap-3 sm:mt-7">
          {ctas?.primary && (
            <a
              href={ctas.primary.href}
              class="inline-flex items-center bg-fg-cyan px-5 py-2.5 font-data text-xs uppercase tracking-[0.15em] text-fg-black shadow-[0_0_24px_-4px_rgba(121,175,191,0.32)] transition-colors hover:bg-fg-white hover:text-fg-black focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-fg-cyan"
            >
              {ctas.primary.label}
            </a>
          )}
          {ctas?.secondary && (
            <a
              href={ctas.secondary.href}
              class="inline-flex items-center border border-fg-phosphor/35 bg-black/20 px-5 py-2.5 font-data text-xs uppercase tracking-[0.15em] text-fg-phosphor transition-colors hover:border-fg-cyan hover:text-fg-cyan focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-fg-cyan"
            >
              {ctas.secondary.label}
            </a>
          )}
        </div>
      )}

      {featured && (
        <a
          href={featured.href}
          class="group relative mt-4 sm:mt-5 lg:mt-6 block overflow-hidden border border-white/12 border-l-2 border-l-fg-phosphor/60 shadow-[0_0_40px_-20px_rgba(0,229,255,0.4)] transition-colors hover:border-white/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-fg-cyan"
          style="min-height:10rem"
        >
          {/* Imagen de fondo full-width */}
          {featured.image && (
            <div class="absolute inset-0">
              <img
                src={featured.image}
                alt=""
                aria-hidden="true"
                class="h-full w-full object-cover object-[center_35%] transition-transform duration-700 group-hover:scale-[1.02]"
                loading="eager"
                decoding="async"
              />
              {/* Overlay: oscuro a izquierda donde va el texto, transparente a la derecha */}
              <div class="absolute inset-0 bg-linear-to-r from-black/85 via-black/55 to-black/10" aria-hidden="true"></div>
              <div class="absolute inset-0 shadow-[inset_0_0_0_1px_rgba(0,229,255,0.12)]" aria-hidden="true"></div>
            </div>
          )}
          {/* Contenido sobre la imagen */}
          <div class="relative z-10 flex flex-col gap-2.5 p-5 sm:max-w-[55%] sm:p-6 lg:p-7">
            <div class="flex items-center gap-2">
              <PillarPill pilar={featured.pilar} size="sm" />
              <span class="font-data text-[10px] uppercase tracking-[0.2em] text-fg-gray/90">Señal destacada</span>
            </div>
            <h2 class="text-base font-semibold leading-snug text-fg-white transition-colors group-hover:text-fg-cyan sm:text-lg lg:text-xl">
              {featured.title}
            </h2>
            {featured.description && (
              <p class="line-clamp-2 text-xs leading-relaxed text-fg-gray/75">
                {featured.description}
              </p>
            )}
            <span class="mt-0.5 inline-flex items-center gap-1 font-data text-xs uppercase tracking-[0.15em] text-fg-cyan">
              <span>Leer análisis</span>
              <span class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </div>
        </a>
      )}
    </div>
  </div>
</section>
