---
import PillarPill from '../PillarPill.astro';
import SignalNode from '../SignalNode.astro';

interface Article {
  title: string;
  description: string;
  slug: string;
  pilar: 'p1' | 'p2' | 'p3' | 'p4';
  date: Date;
  image?: string;
}

interface Props {
  label?: string;
  headline: string;
  subheadline?: string;
  featured: Article;
  secondary?: Article[];
}

const { label = 'Señal fuerte', headline, subheadline, featured, secondary = [] } = Astro.props;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('es-MX', {
    day: '2-digit',
    month: 'short',
  });
};

const linkFocus =
  'focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-fg-cyan rounded-sm';

const pillarTop = {
  p1: 'border-t-pilar-p1/55',
  p2: 'border-t-pilar-p2/55',
  p3: 'border-t-pilar-p3/55',
  p4: 'border-t-pilar-p4/55',
} as const;

const isTechnoDetroitCover = featured.image.includes('techno-detroit-hero');
---

<section class="fg-fallout-matrix relative overflow-hidden border-b border-white/10 pt-10 pb-16 lg:pt-12 lg:pb-24">
  <div class="pointer-events-none absolute inset-0 opacity-[0.055]" aria-hidden="true">
    <img
      src="/images/sections/fg-section-archive.png"
      alt=""
      class="h-full w-full object-cover mix-blend-soft-light"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div
    class="pointer-events-none absolute inset-0 bg-[url('/images/system/fg-overlay-section-weave.svg')] bg-cover bg-[center_top] opacity-[0.36]"
    aria-hidden="true"
  ></div>
  <div class="relative mx-auto max-w-[1400px] px-6 lg:px-12">
    <div class="flex items-center gap-4 mb-10">
      <SignalNode size="md" />
      <div>
        <p class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-cyan">{label}</p>
        <h2 class="font-display text-3xl text-fg-white sm:text-[2.7rem] tracking-wide mt-1">{headline}</h2>
        {subheadline && <p class="text-fg-gray mt-2 max-w-2xl text-sm sm:text-base">{subheadline}</p>}
      </div>
    </div>

    <div class="space-y-7">
      <article class="group rounded-sm border border-white/10 bg-black/20 px-4 py-5 sm:px-5 lg:px-7 lg:py-7 shadow-[0_0_40px_-26px_rgba(0,229,255,0.5)]">
        {featured.image && (
          <a
            href={`/contenido/${featured.slug}`}
            class:list={['fg-corner-cut relative block mb-7 overflow-hidden border border-fg-cyan/25 aspect-video', linkFocus]}
          >
            <div class="absolute inset-0" aria-hidden="true">
              <img src="/images/hero/fg-hero-atmosphere-grid.png" alt="" class="h-full w-full object-cover opacity-40 mix-blend-screen" loading="lazy" decoding="async" />
            </div>
            <img
              src={featured.image}
              alt={featured.title}
              class:list={[
                'relative z-10 h-full w-full object-cover transition-[transform,opacity] duration-300 group-hover:scale-[1.02] group-hover:opacity-95',
                isTechnoDetroitCover && 'grayscale contrast-[1.12] saturate-0',
              ]}
            />
            {isTechnoDetroitCover && (
              <div class="pointer-events-none absolute right-0 top-0 z-[11] h-[44%] w-[40%] bg-[radial-gradient(circle_at_100%_0%,rgba(0,229,255,0.92),rgba(0,229,255,0.34)_24%,rgba(255,0,229,0.16)_54%,transparent_80%)] opacity-85 mix-blend-screen" aria-hidden="true"></div>
            )}
            <div class="pointer-events-none absolute inset-0 z-20 opacity-[0.36]" aria-hidden="true">
              <img src="/images/system/fg-overlay-article-frame.svg" alt="" class="h-full w-full object-cover" loading="lazy" decoding="async" />
            </div>
          </a>
        )}

        <div class="flex items-center gap-3 mb-5">
          <PillarPill pilar={featured.pilar} size="md" />
          <span class="font-data text-[11px] uppercase tracking-[0.24em] text-fg-gray">
            {formatDate(featured.date)}
          </span>
        </div>

        <a href={`/contenido/${featured.slug}`} class:list={['group/title block', linkFocus]}>
          <h3 class="text-3xl font-bold leading-tight text-fg-white transition-colors duration-300 group-hover/title:text-fg-cyan sm:text-[2.55rem] lg:text-[3.25rem] max-w-4xl">
            {featured.title}
          </h3>
        </a>

        <p class="mt-4 text-base sm:text-lg leading-relaxed text-fg-gray max-w-3xl line-clamp-4 sm:line-clamp-none">
          {featured.description}
        </p>

        <a
          href={`/contenido/${featured.slug}`}
          class:list={[
            'inline-flex items-center gap-2 mt-6 font-data text-xs sm:text-sm uppercase tracking-[0.2em] text-fg-cyan hover:text-fg-white transition-colors',
            linkFocus,
          ]}
        >
          <span>Leer análisis completo</span>
          <span class="transition-opacity duration-300 group-hover:opacity-80">→</span>
        </a>
      </article>

      {secondary.length > 0 && (
        <div class="border-t border-white/10 pt-8">
          <p class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-gray mb-6">Más señales recientes</p>

          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {secondary.map((article) => (
              <article
                class:list={[
                  'fg-corner-cut group flex flex-col border border-white/10 bg-black/35 p-5 pt-6 transition-colors duration-300 hover:border-white/20 hover:bg-black/45',
                  'border-t-2',
                  pillarTop[article.pilar],
                ]}
              >
                <div class="flex items-center gap-2 mb-3">
                  <PillarPill pilar={article.pilar} size="sm" />
                  <span class="font-data text-[10px] text-fg-gray/70">{formatDate(article.date)}</span>
                </div>

                <a href={`/contenido/${article.slug}`} class:list={['group/title block', linkFocus]}>
                  <h4 class="text-base font-semibold leading-snug text-fg-white transition-colors duration-300 group-hover/title:text-fg-cyan">
                    {article.title}
                  </h4>
                </a>

                <p class="mt-2 text-sm text-fg-gray/85 line-clamp-2 leading-relaxed">
                  {article.description}
                </p>
              </article>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</section>
