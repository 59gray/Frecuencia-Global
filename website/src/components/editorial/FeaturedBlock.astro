---
import PillarPill from '../PillarPill.astro';
import SignalNode from '../SignalNode.astro';

interface Article {
  title: string;
  description: string;
  slug: string;
  pilar: 'p1' | 'p2' | 'p3' | 'p4';
  date: Date;
  image?: string;
}

interface Props {
  label?: string;
  headline: string;
  subheadline?: string;
  featured: Article;
  secondary?: Article[];
}

const { label = 'Señal fuerte', headline, subheadline, featured, secondary = [] } = Astro.props;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('es-MX', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  });
};

const linkFocus =
  'focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-fg-cyan rounded-sm';

const pillarTop = {
  p1: 'border-t-pilar-p1/55',
  p2: 'border-t-pilar-p2/55',
  p3: 'border-t-pilar-p3/55',
  p4: 'border-t-pilar-p4/55',
} as const;

const pillarMeta: Record<string, { tag: string; accent: string }> = {
  p1: { tag: 'Geopolítica', accent: 'text-pilar-p1' },
  p2: { tag: 'Cultura electrónica', accent: 'text-pilar-p2' },
  p3: { tag: 'Tecnología global', accent: 'text-pilar-p3' },
  p4: { tag: 'Política pública', accent: 'text-pilar-p4' },
};

const meta = pillarMeta[featured.pilar] ?? { tag: 'Editorial', accent: 'text-fg-cyan' };
const isTechnoDetroit = featured.image?.includes('DETROIT') || featured.image?.includes('detroit');
---

<section class="fg-fallout-matrix relative overflow-hidden border-b border-white/10 pt-10 pb-16 lg:pt-14 lg:pb-24">
  <div class="pointer-events-none absolute inset-0 opacity-[0.055]" aria-hidden="true">
    <img
      src="/images/sections/fg-section-archive.png"
      alt=""
      class="h-full w-full object-cover mix-blend-soft-light"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div
    class="pointer-events-none absolute inset-0 bg-[url('/images/system/fg-overlay-section-weave.svg')] bg-cover bg-[center_top] opacity-[0.36]"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-[1400px] px-6 lg:px-12">

    <!-- Section header -->
    <div class="flex items-center gap-4 mb-10">
      <SignalNode size="md" />
      <div>
        <p class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-cyan">{label}</p>
        <h2 class="font-display text-3xl text-fg-white sm:text-[2.7rem] tracking-wide mt-1">{headline}</h2>
        {subheadline && <p class="text-fg-gray mt-2 max-w-2xl text-sm sm:text-base">{subheadline}</p>}
      </div>
    </div>

    <!-- Featured article — editorial layout -->
    <article class="group relative rounded-sm border border-white/12 bg-black/25 shadow-[0_0_60px_-30px_rgba(0,229,255,0.4)] overflow-hidden">

      <!-- Top accent bar -->
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-fg-cyan/50 to-transparent" aria-hidden="true"></div>

      <div style="width:100%" class="grid lg:grid-cols-[1fr_0.85fr] min-h-[420px]">

        <!-- Left: editorial content panel -->
        <div style="min-width:0;width:100%" class="flex flex-col justify-between p-6 sm:p-8 lg:p-10 xl:p-12">

          <!-- Top badges row -->
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class="inline-flex items-center gap-1.5 border border-fg-cyan/40 bg-fg-cyan/8 px-2.5 py-1 font-data text-[10px] uppercase tracking-[0.26em] text-fg-cyan">
              <span class="h-1.5 w-1.5 rounded-full bg-fg-cyan animate-pulse"></span>
              SEÑAL DESTACADA
            </span>
            <PillarPill pilar={featured.pilar} size="md" />
            {isTechnoDetroit && (
              <span class="border border-pilar-p2/35 bg-pilar-p2/8 px-2.5 py-1 font-data text-[10px] uppercase tracking-[0.24em] text-pilar-p2">
                PILOTO FG
              </span>
            )}
          </div>

          <!-- Title -->
          <div class="flex-1">
            <a href={`/contenido/${featured.slug}`} class:list={['group/title block', linkFocus]}>
              <h3 class="text-2xl font-bold leading-tight text-fg-white transition-colors duration-300 group-hover/title:text-fg-cyan sm:text-3xl lg:text-[2.6rem] xl:text-[3rem] max-w-xl lg:leading-[1.05]">
                {featured.title}
              </h3>
            </a>

            <p style="white-space:normal;word-break:normal;overflow-wrap:break-word" class="mt-5 text-base leading-relaxed text-fg-gray/90 max-w-lg">
              {isTechnoDetroit
                ? 'De las fábricas de Detroit a las pistas del mundo: una historia de migración cultural, resistencia y frecuencia electrónica.'
                : featured.description}
            </p>
          </div>

          <!-- Bottom metadata + CTA -->
          <div class="mt-8 pt-6 border-t border-white/10">
            <div class="flex flex-wrap items-center justify-between gap-4">
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
                <span class:list={['font-data text-[11px] uppercase tracking-[0.22em]', meta.accent]}>
                  {meta.tag}
                </span>
                {isTechnoDetroit && (
                  <span class="font-data text-[11px] uppercase tracking-[0.22em] text-fg-gray/60">Detroit</span>
                )}
                <time class="font-data text-[11px] uppercase tracking-[0.22em] text-fg-gray/50" datetime={featured.date.toISOString()}>
                  {formatDate(featured.date)}
                </time>
              </div>
              <a
                href={`/contenido/${featured.slug}`}
                class:list={[
                  'inline-flex items-center gap-2 font-data text-xs uppercase tracking-[0.22em] text-fg-cyan hover:text-fg-white transition-colors duration-200',
                  linkFocus,
                ]}
              >
                <span>Leer análisis</span>
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </div>

        <!-- Right: image panel -->
        {featured.image && (
          <a
            href={`/contenido/${featured.slug}`}
            class:list={['relative block overflow-hidden border-l border-white/10 bg-black/40 min-h-[280px] lg:min-h-0', linkFocus]}
          >
            <div class="absolute inset-0" aria-hidden="true">
              <img src="/images/hero/fg-hero-atmosphere-grid.png" alt="" class="h-full w-full object-cover opacity-30 mix-blend-screen" loading="lazy" decoding="async" />
            </div>
            <img
              src={featured.image}
              alt={featured.title}
              class:list={[
                'absolute inset-0 h-full w-full object-cover transition-[transform,opacity] duration-500 group-hover:scale-[1.03] group-hover:opacity-90',
                isTechnoDetroit && 'grayscale contrast-[1.15] saturate-0',
              ]}
            />
            {isTechnoDetroit && (
              <>
                <div class="pointer-events-none absolute right-0 top-0 z-10 h-[55%] w-[55%] bg-[radial-gradient(circle_at_100%_0%,rgba(0,229,255,0.85),rgba(0,229,255,0.28)_30%,rgba(255,0,229,0.14)_60%,transparent_80%)] opacity-75 mix-blend-screen" aria-hidden="true"></div>
                <div class="pointer-events-none absolute bottom-0 left-0 right-0 z-10 h-1/3 bg-gradient-to-t from-black/70 to-transparent" aria-hidden="true"></div>
                <div class="absolute bottom-4 left-4 z-20 font-data text-[10px] uppercase tracking-[0.28em] text-fg-cyan/70">
                  Detroit · Bass &amp; Borders
                </div>
              </>
            )}
            <div class="pointer-events-none absolute inset-0 z-20 opacity-[0.28]" aria-hidden="true">
              <img src="/images/system/fg-overlay-article-frame.svg" alt="" class="h-full w-full object-cover" loading="lazy" decoding="async" />
            </div>
          </a>
        )}
      </div>
    </article>

    <!-- Secondary articles -->
    {secondary.length > 0 && (
      <div class="border-t border-white/10 pt-8 mt-8">
        <p class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-gray mb-6">Más señales recientes</p>

        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {secondary.map((article) => (
            <article
              class:list={[
                'fg-corner-cut group flex flex-col border border-white/10 bg-black/35 p-5 pt-6 transition-colors duration-300 hover:border-white/20 hover:bg-black/45',
                'border-t-2',
                pillarTop[article.pilar],
              ]}
            >
              <div class="flex items-center gap-2 mb-3">
                <PillarPill pilar={article.pilar} size="sm" />
                <span class="font-data text-[10px] text-fg-gray/70">{formatDate(article.date)}</span>
              </div>

              <a href={`/contenido/${article.slug}`} class:list={['group/title block', linkFocus]}>
                <h4 class="text-base font-semibold leading-snug text-fg-white transition-colors duration-300 group-hover/title:text-fg-cyan">
                  {article.title}
                </h4>
              </a>

              <p class="mt-2 text-sm text-fg-gray/85 line-clamp-2 leading-relaxed">
                {article.description}
              </p>
            </article>
          ))}
        </div>
      </div>
    )}

  </div>
</section>
