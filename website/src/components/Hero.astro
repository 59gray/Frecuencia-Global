---
import PillarPill from './PillarPill.astro';
import SignalNode from './SignalNode.astro';

interface FeaturedArticle {
  title: string;
  description: string;
  href: string;
  dateLabel: string;
  pilar: 'p1' | 'p2' | 'p3' | 'p4';
}

interface SignalStat {
  label: string;
  value: string;
  tone?: 'cyan' | 'magenta' | 'green' | 'blue';
}

interface Props {
  title: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  backgroundImage?: string;
  featuredArticle?: FeaturedArticle;
  stats?: SignalStat[];
  tickerItems?: string[];
}

const {
  title,
  subtitle,
  ctaLabel,
  ctaHref,
  secondaryLabel,
  secondaryHref,
  backgroundImage,
  featuredArticle,
  stats = [],
  tickerItems = [],
} = Astro.props;

const titleParts = title.split(' ');

const statToneMap: Record<NonNullable<SignalStat['tone']>, string> = {
  cyan: 'text-fg-cyan',
  magenta: 'text-pilar-p2',
  green: 'text-pilar-p3',
  blue: 'text-pilar-p4',
};
---

<section class="relative isolate overflow-hidden border-b border-white/10">
  {backgroundImage && (
    <div
      class="absolute inset-0 scale-[1.03] bg-cover bg-center opacity-34 blur-[2px] lg:bg-right"
      style={`background-image: url('${backgroundImage}');`}
      aria-hidden="true"
    ></div>
  )}
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(0,229,255,0.18),transparent_30%),radial-gradient(circle_at_82%_14%,rgba(255,0,229,0.12),transparent_22%),linear-gradient(135deg,rgba(255,255,255,0.02),transparent_42%)]" aria-hidden="true"></div>
  <div class="signal-grid absolute inset-0 opacity-40" aria-hidden="true"></div>
  <div class="signal-scan absolute inset-y-0 left-[-12%] w-[52%] bg-[linear-gradient(90deg,transparent,rgba(0,229,255,0.14),transparent)] blur-3xl" aria-hidden="true"></div>
  <div class="signal-drift absolute right-[6%] top-[18%] h-28 w-28 rounded-full border border-white/10 bg-white/5 shadow-[0_0_80px_rgba(255,0,229,0.14)]" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto grid min-h-[calc(100svh-4rem)] max-w-[1500px] items-end gap-10 px-md pb-12 pt-12 lg:grid-cols-[minmax(0,1.35fr)_minmax(320px,0.72fr)] lg:px-xl lg:pb-16 lg:pt-16">
    <div>
      <div class="mb-6 flex flex-wrap items-center gap-3 font-data text-[11px] uppercase tracking-[0.32em] text-fg-gray">
        <span class="inline-flex items-center gap-2">
          <SignalNode size="sm" />
          análisis internacional
        </span>
        <span class="hidden text-white/15 sm:inline">/</span>
        <span class="text-white/60">club signal</span>
      </div>

      <p class="mb-5 font-data text-[11px] uppercase tracking-[0.36em] text-fg-cyan/90">
        geopolítica · cultura · tecnología · pulso nocturno
      </p>

      <h1 class="max-w-[10ch] font-display text-[clamp(4.5rem,16vw,11rem)] leading-[0.82] tracking-[0.08em] text-fg-white">
        <span class="block">{titleParts[0]}</span>
        <span class="block text-transparent [-webkit-text-stroke:1px_rgba(255,255,255,0.68)]">
          {titleParts.slice(1).join(' ')}
        </span>
      </h1>

      {subtitle && (
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-fg-gray sm:text-xl">
          {subtitle}
        </p>
      )}

      <div class="mt-8 flex flex-wrap gap-4">
        {ctaLabel && ctaHref && (
          <a
            href={ctaHref}
            class="inline-flex items-center justify-center border border-fg-cyan bg-fg-cyan px-5 py-3 font-data text-xs uppercase tracking-[0.26em] text-fg-black transition-transform duration-300 hover:-translate-y-0.5"
          >
            {ctaLabel}
          </a>
        )}
        {secondaryLabel && secondaryHref && (
          <a
            href={secondaryHref}
            class="inline-flex items-center justify-center border border-white/15 px-5 py-3 font-data text-xs uppercase tracking-[0.26em] text-fg-white transition-colors duration-300 hover:border-white/40 hover:bg-white/5"
          >
            {secondaryLabel}
          </a>
        )}
      </div>

      {stats.length > 0 && (
        <dl class="mt-10 grid max-w-4xl gap-4 sm:grid-cols-3">
          {stats.map((stat) => (
            <div class="border-t border-white/10 pt-4">
              <dt class="font-data text-[10px] uppercase tracking-[0.28em] text-fg-gray">{stat.label}</dt>
              <dd class:list={['mt-2 font-display text-3xl tracking-[0.08em] text-fg-white sm:text-4xl', stat.tone ? statToneMap[stat.tone] : '']}>
                {stat.value}
              </dd>
            </div>
          ))}
        </dl>
      )}
    </div>

    <aside class="relative overflow-hidden border border-white/10 bg-black/35 px-6 py-6 backdrop-blur-xl sm:px-7 sm:py-8">
      <div class="absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,rgba(255,255,255,0.6),transparent)]" aria-hidden="true"></div>
      <p class="font-data text-[11px] uppercase tracking-[0.32em] text-fg-gray">current drop</p>

      {featuredArticle ? (
        <div class="mt-5">
          <PillarPill pilar={featuredArticle.pilar} size="md" />
          <a href={featuredArticle.href} class="mt-5 block">
            <h2 class="font-display text-3xl leading-[0.9] tracking-[0.05em] text-fg-white transition-colors duration-300 hover:text-fg-cyan">
              {featuredArticle.title}
            </h2>
          </a>
          <p class="mt-4 text-sm leading-relaxed text-fg-gray">
            {featuredArticle.description}
          </p>
          <div class="mt-6 font-data text-[11px] uppercase tracking-[0.28em] text-fg-gray">
            {featuredArticle.dateLabel}
          </div>
          <a
            href={featuredArticle.href}
            class="mt-6 inline-flex items-center font-data text-xs uppercase tracking-[0.26em] text-fg-cyan transition-colors duration-300 hover:text-fg-white"
          >
            leer transmisión →
          </a>
        </div>
      ) : (
        <div class="mt-5 space-y-4">
          <h2 class="font-display text-3xl leading-[0.9] tracking-[0.05em] text-fg-white">La señal ya está encendida.</h2>
          <p class="text-sm leading-relaxed text-fg-gray">
            La primera tanda de piezas ya está publicada y este bloque se actualizará automáticamente con el drop más reciente.
          </p>
        </div>
      )}

      {tickerItems.length > 0 && (
        <div class="mt-8 border-t border-white/10 pt-6">
          <p class="font-data text-[11px] uppercase tracking-[0.32em] text-fg-gray">señal base</p>
          <ul class="mt-4 space-y-3">
            {tickerItems.slice(0, 4).map((item) => (
              <li class="flex items-center gap-3 text-sm text-fg-gray">
                <SignalNode size="sm" color="var(--color-fg-cyan)" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </aside>
  </div>

  {tickerItems.length > 0 && (
    <div class="border-t border-white/10 bg-black/30 backdrop-blur-sm">
      <div class="signal-marquee overflow-hidden">
        <div class="signal-marquee-track flex w-max gap-8 px-md py-3 lg:px-xl">
          {[...tickerItems, ...tickerItems].map((item) => (
            <span class="font-data text-[11px] uppercase tracking-[0.34em] text-white/65">
              {item}
            </span>
          ))}
        </div>
      </div>
    </div>
  )}
</section>
