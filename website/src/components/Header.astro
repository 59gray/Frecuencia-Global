---
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Inicio', href: '/' },
  {
    label: 'Pilares',
    href: '/pilares',
    children: [
      { label: 'Geopolitik Drop', href: '/pilares/geopolitik-drop', color: 'text-pilar-p1' },
      { label: 'Bass & Borders', href: '/pilares/bass-and-borders', color: 'text-pilar-p2' },
      { label: 'Frecuencia Global', href: '/pilares/frecuencia-global', color: 'text-pilar-p3' },
      { label: 'Behind the Policy', href: '/pilares/behind-the-policy', color: 'text-pilar-p4' },
    ],
  },
  { label: 'Contenido', href: '/contenido' },
  { label: 'Podcast', href: '/podcast' },
  { label: 'Sobre', href: '/sobre' },
  { label: 'Contacto', href: '/contacto' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-fg-black/75 backdrop-blur-xl">
  <nav class="mx-auto flex h-16 max-w-[1500px] items-center justify-between px-md lg:px-xl">
    <a href="/" class="flex items-center gap-3">
      <span class="relative flex h-10 w-10 items-center justify-center border border-white/10 bg-white/5">
        <img src="/images/logo/fg_isotipo.svg" alt="Frecuencia Global" class="h-6 w-6" />
        <span class="absolute -right-1 -top-1 h-2.5 w-2.5 rounded-full bg-fg-cyan shadow-[0_0_12px_rgba(0,229,255,0.9)]"></span>
      </span>
      <span class="hidden sm:block">
        <span class="block font-display text-[1.15rem] tracking-[0.18em] text-fg-white">FRECUENCIA GLOBAL</span>
        <span class="hidden font-data text-[10px] uppercase tracking-[0.28em] text-fg-gray lg:block">
          análisis internacional / club signal
        </span>
      </span>
    </a>

    <ul class="hidden items-center gap-2 md:flex">
      {navItems.map((item) => (
        <li class="relative group">
          <a
            href={item.href}
            class:list={[
              'inline-flex items-center gap-1 px-3 py-2 font-data text-[11px] uppercase tracking-[0.22em] transition-colors duration-300',
              item.label === 'Contacto'
                ? isActive(item.href)
                  ? 'border border-fg-cyan bg-fg-cyan text-fg-black'
                  : 'border border-white/15 text-fg-white hover:border-white/35 hover:bg-white/5'
                : isActive(item.href)
                  ? 'text-fg-cyan'
                  : 'text-fg-gray hover:text-fg-white',
            ]}
          >
            {item.label}
            {item.children && (
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>

          {item.children && (
            <ul class="absolute left-0 top-full mt-2 min-w-[230px] border border-white/10 bg-fg-black/95 p-2 invisible opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
              {item.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class:list={[
                      'block px-3 py-2 font-data text-[11px] uppercase tracking-[0.22em] transition-colors duration-300 hover:bg-white/5',
                      child.color,
                    ]}
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>

    <button
      id="mobile-menu-btn"
      class="border border-white/10 p-2 text-fg-gray transition-colors duration-300 hover:text-fg-white md:hidden"
      aria-label="Menú"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-white/10 bg-fg-black/95 md:hidden">
    <ul class="space-y-1 px-md py-lg">
      {navItems.map((item) => (
        <>
          <li>
            <a
              href={item.href}
              class:list={[
                'block py-2 font-data text-xs uppercase tracking-[0.24em] transition-colors duration-300',
                isActive(item.href) ? 'text-fg-cyan' : 'text-fg-gray hover:text-fg-white',
              ]}
            >
              {item.label}
            </a>
          </li>
          {item.children?.map((child) => (
            <li>
              <a
                href={child.href}
                class:list={[
                  'block py-2 pl-4 font-data text-[11px] uppercase tracking-[0.22em] transition-colors duration-300',
                  child.color,
                ]}
              >
                {child.label}
              </a>
            </li>
          ))}
        </>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
