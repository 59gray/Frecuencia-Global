---
import { PILLARS, pillarPath, type PillarId } from '../lib/pillars';

const currentPath = Astro.url.pathname;

const pilarNavColor: Record<PillarId, string> = {
  p1: 'text-pilar-p1',
  p2: 'text-pilar-p2',
  p3: 'text-pilar-p3',
  p4: 'text-pilar-p4',
};

const navItems = [
  { label: 'Inicio', href: '/' },
  {
    label: 'Frecuencias',
    href: '/pilares',
    children: PILLARS.map((p) => ({
      label: p.titleEs,
      href: pillarPath(p.slug),
      color: pilarNavColor[p.id],
    })),
  },
  { label: 'Archivo', href: '/contenido' },
  { label: 'Podcast', href: '/podcast' },
  { label: 'About', href: '/sobre' },
  { label: 'Contacto', href: '/contacto' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-[90] px-2 pt-2 sm:px-3 sm:pt-3">
  <div class="fg-tactical-panel fg-tactical-panel--nav fg-nav-shell fg-divider-hairline border-cyan-500/20">
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-10 bg-[linear-gradient(180deg,rgba(121,175,191,0.06),transparent)]"
      aria-hidden="true"
    ></div>

    <nav class="relative mx-auto flex h-[4.25rem] max-w-[1500px] items-center justify-between px-fg-md lg:px-fg-xl">
      <a href="/" class="flex min-w-0 items-center gap-3">
        <span class="relative flex h-10 w-10 shrink-0 items-center justify-center overflow-hidden rounded-full border border-cyan-500/35 bg-[rgba(10,10,15,0.96)] shadow-[0_0_18px_-8px_rgba(0,229,255,0.7)]">
          <img src="/images/logo/fg_isotipo_512.png" alt="Frecuencia Global" class="h-full w-full object-cover" />
        </span>

        <span class="hidden min-w-0 sm:block">
          <span class="inline-flex items-center gap-2 border border-fg-cyan/35 bg-black/25 px-2.5 py-1 font-data text-[10px] uppercase tracking-[0.22em] text-fg-cyan">
            <span class="h-1.5 w-1.5 rounded-full bg-fg-cyan animate-pulse"></span>
            señal central
          </span>
          <span class="mt-0.5 hidden items-center gap-2 font-data text-[10px] uppercase tracking-[0.28em] text-fg-gray lg:flex">
            <span class="text-fg-cyan">analisis internacional</span>
            <span class="text-fg-phosphor">pulso crítico</span>
          </span>
        </span>
      </a>

      <ul class="hidden items-center gap-1 md:flex">
        {navItems.map((item) => (
          <li class="group relative z-20 after:absolute after:left-0 after:right-0 after:top-full after:h-2 after:content-[''] hover:z-40 focus-within:z-40">
            <a
              href={item.href}
              title={item.label === 'Frecuencias' ? 'Descubre las frecuencias de análisis' : undefined}
              class:list={[
                'relative inline-flex items-center gap-1 px-3 py-2 font-data text-[11px] uppercase tracking-[0.22em] transition-colors duration-200',
                'after:absolute after:bottom-1 after:left-3 after:h-px after:w-[calc(100%-1.5rem)] after:origin-left after:scale-x-0 after:bg-fg-cyan after:transition-transform after:duration-200',
                item.label === 'Contacto'
                  ? isActive(item.href)
                    ? 'fg-corner-cut border border-fg-cyan bg-fg-cyan text-fg-black hover:text-fg-black'
                    : 'fg-corner-cut border border-white/20 text-fg-white hover:border-fg-cyan/60 hover:text-fg-cyan'
                  : item.label === 'Frecuencias'
                    ? isActive(item.href)
                      ? 'fg-corner-cut border border-fg-cyan/70 bg-fg-cyan/10 text-fg-cyan after:scale-x-100'
                      : 'fg-corner-cut border border-fg-cyan/45 bg-fg-cyan/6 text-fg-white after:scale-x-100 hover:border-fg-cyan/75 hover:text-fg-cyan'
                  : isActive(item.href)
                    ? 'text-fg-cyan after:scale-x-100'
                    : 'text-fg-gray hover:text-fg-white group-hover:after:scale-x-100',
              ]}
            >
              {item.label}
              {item.label === 'Frecuencias' && (
                <span class="hidden items-center gap-1 rounded-sm border border-fg-cyan/45 bg-fg-cyan/14 px-1.5 py-0.5 font-data text-[9px] tracking-[0.22em] text-fg-cyan md:inline-flex">
                  <span class="h-1 w-1 rounded-full bg-fg-cyan"></span>
                  04
                </span>
              )}
              {item.children && (
                <svg class="h-3 w-3 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>

            {item.children && (
              <ul class="fg-dropdown-panel invisible absolute left-1/2 top-[calc(100%-1px)] z-[140] min-w-[340px] -translate-x-1/2 p-2 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={[
                        'block whitespace-nowrap px-3 py-2 font-data text-[11px] uppercase tracking-[0.22em] transition-colors duration-200 hover:bg-white/5',
                        child.color,
                      ]}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>

      <button
        id="mobile-menu-btn"
        class="fg-corner-cut border border-fg-cyan/45 bg-fg-cyan/10 p-2.5 text-fg-cyan shadow-[0_0_20px_-10px_rgba(0,229,255,0.65)] transition-colors duration-200 hover:border-fg-cyan hover:bg-fg-cyan/16 hover:text-fg-white md:hidden"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>

    <div id="mobile-menu" class="hidden border-t border-white/12 bg-fg-black/92 md:hidden">
      <ul class="max-w-full space-y-1 px-fg-md py-fg-lg">
        {navItems.map((item) => (
          <>
            <li>
              <a
                href={item.href}
                class:list={[
                  'block max-w-full py-2 break-words font-data text-xs uppercase tracking-[0.24em] leading-snug transition-colors duration-200',
                  isActive(item.href) ? 'text-fg-cyan' : 'text-fg-gray hover:text-fg-white',
                ]}
              >
                {item.label}
              </a>
            </li>
            {item.children?.map((child) => (
              <li>
                <a
                  href={child.href}
                  class:list={[
                    'block max-w-full py-2 pl-4 pr-2 break-words font-data text-[10px] uppercase tracking-[0.2em] leading-snug transition-colors duration-200 sm:text-[11px] sm:tracking-[0.22em]',
                    child.color,
                  ]}
                >
                  {child.label}
                </a>
              </li>
            ))}
          </>
        ))}
      </ul>
    </div>

    <div class="hidden items-center justify-between border-t border-white/10 px-fg-md py-2 font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray lg:flex lg:px-fg-xl">
      <span>edicion en curso</span>
      <span class="text-fg-phosphor">geopolitica, cultura y política global</span>
      <span class="text-fg-cyan">actualizado</span>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
