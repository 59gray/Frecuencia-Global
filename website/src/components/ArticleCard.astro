---
import PillarPill from './PillarPill.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  pilar: 'p1' | 'p2' | 'p3' | 'p4';
  slug: string;
  image?: string;
}

const { title, description, date, pilar, slug, image } = Astro.props;

const formattedDate = date.toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});

const linkFocus =
  'focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-fg-cyan rounded-sm';

const pillarTop = {
  p1: 'border-t-pilar-p1/50',
  p2: 'border-t-pilar-p2/50',
  p3: 'border-t-pilar-p3/50',
  p4: 'border-t-pilar-p4/50',
} as const;
---

<article
  class:list={[
    'group fg-tactical-panel fg-corner-cut relative flex h-full flex-col p-5 pt-6 transition-colors duration-300 hover:border-white/25',
    'border-t-2',
    pillarTop[pilar],
  ]}
>
  <span class="pointer-events-none absolute right-4 top-3 font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray/45" aria-hidden="true">
    señal visual
  </span>

  {image && (
    <a href={`/contenido/${slug}`} class:list={['fg-corner-cut mb-4 block aspect-[2.2/1] overflow-hidden border border-white/12 bg-fg-surface/35', linkFocus]}>
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-[transform,opacity] duration-300 group-hover:scale-[1.02] group-hover:opacity-95"
        loading="lazy"
      />
    </a>
  )}

  <div class="flex flex-wrap items-center justify-between gap-2">
    <PillarPill pilar={pilar} size="sm" />
    <time class="font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray" datetime={date.toISOString()}>
      {formattedDate}
    </time>
  </div>

  <a href={`/contenido/${slug}`} class:list={['mt-3 block', linkFocus]}>
    <h3 class="text-lg font-semibold leading-snug text-fg-white transition-colors duration-300 group-hover:text-fg-cyan sm:text-xl">
      {title}
    </h3>
  </a>

  <p class="mt-2 flex-1 text-sm leading-relaxed text-fg-gray/90 line-clamp-3">
    {description}
  </p>

  <span class="mt-4 inline-flex items-center gap-2 font-data text-[10px] uppercase tracking-[0.22em] text-fg-cyan/90">
    <span>LEER SEÑAL</span>
    <span aria-hidden="true">→</span>
  </span>
</article>
