---
import PillarPill from './PillarPill.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  pilar: 'p1' | 'p2' | 'p3' | 'p4';
  slug: string;
  image?: string;
}

const { title, description, date, pilar, slug, image } = Astro.props;

const formattedDate = date.toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
---

<article class="group border-t border-white/10 pt-md">
  {image && (
    <a href={`/contenido/${slug}`} class="mb-md block aspect-[4/3] overflow-hidden border border-white/10 bg-fg-surface/30">
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
        loading="lazy"
      />
    </a>
  )}

  <div class="flex flex-wrap items-center justify-between gap-3">
    <PillarPill pilar={pilar} />
    <time class="font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray" datetime={date.toISOString()}>
      {formattedDate}
    </time>
  </div>

  <a href={`/contenido/${slug}`} class="mt-sm block">
    <h3 class="font-display text-2xl leading-[0.9] tracking-[0.05em] text-fg-white transition-colors duration-300 group-hover:text-fg-cyan">
      {title}
    </h3>
  </a>

  <p class="mt-sm text-sm leading-relaxed text-fg-gray">
    {description}
  </p>
</article>
