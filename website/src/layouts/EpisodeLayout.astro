---
import BaseLayout from './BaseLayout.astro';
import PillarPill from '../components/PillarPill.astro';
import FrequencyLine from '../components/FrequencyLine.astro';

interface PlatformLinks {
  spotify?: string;
  apple?: string;
  youtube?: string;
}

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  pilar: 'p1' | 'p2' | 'p3' | 'p4';
  season: number;
  episodeNumber: number;
  duration: string;
  audioUrl: string;
  coverImage: string;
  youtubeVideoId: string;
  videoMode: 'editorial-visualizer' | 'on-camera' | 'hybrid';
  explicit: boolean;
  platformLinks?: PlatformLinks;
}

const {
  title,
  description,
  publishDate,
  pilar,
  season,
  episodeNumber,
  duration,
  audioUrl,
  coverImage,
  youtubeVideoId,
  videoMode,
  explicit,
  platformLinks = {},
} = Astro.props;

const dateFormatted = publishDate.toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const platformButtons = [
  platformLinks.spotify ? { label: 'Spotify', href: platformLinks.spotify } : null,
  platformLinks.apple ? { label: 'Apple Podcasts', href: platformLinks.apple } : null,
  platformLinks.youtube ? { label: 'YouTube', href: platformLinks.youtube } : null,
].filter(Boolean) as { label: string; href: string }[];

const videoModeLabel = videoMode === 'editorial-visualizer' ? 'Visualizer editorial 16:9' : videoMode;
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  pilar={pilar}
  image={coverImage}
>
  <article class="mx-auto max-w-[1500px] px-md py-2xl lg:px-xl">
    <header class="grid gap-10 border-b border-white/10 pb-xl lg:grid-cols-[minmax(0,1.2fr)_380px]">
      <div>
        <div class="flex flex-wrap items-center gap-3">
          <PillarPill pilar={pilar} size="md" />
          <span class="font-data text-[11px] uppercase tracking-[0.28em] text-fg-gray">
            temporada {season} / episodio {String(episodeNumber).padStart(2, '0')}
          </span>
        </div>

        <h1 class="mt-5 max-w-[12ch] font-display text-5xl leading-[0.86] tracking-[0.08em] text-fg-white sm:text-6xl">
          {title}
        </h1>

        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-fg-gray">
          {description}
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={`https://www.youtube.com/watch?v=${youtubeVideoId}`}
            class="inline-flex items-center justify-center border border-fg-cyan bg-fg-cyan px-5 py-3 font-data text-xs uppercase tracking-[0.26em] text-fg-black transition-transform duration-300 hover:-translate-y-0.5"
          >
            ver videopodcast
          </a>
          <a
            href={audioUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center border border-white/15 px-5 py-3 font-data text-xs uppercase tracking-[0.26em] text-fg-white transition-colors duration-300 hover:border-white/35 hover:bg-white/5"
          >
            abrir audio
          </a>
          {platformButtons.map((platform) => (
            <a
              href={platform.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center border border-white/15 px-5 py-3 font-data text-xs uppercase tracking-[0.26em] text-fg-gray transition-colors duration-300 hover:border-fg-cyan hover:text-fg-cyan"
            >
              {platform.label}
            </a>
          ))}
        </div>
      </div>

      <aside class="overflow-hidden border border-white/10 bg-white/[0.03]">
        <img src={coverImage} alt={title} class="aspect-video w-full object-cover" />
        <div class="space-y-5 px-6 py-6">
          <dl class="grid grid-cols-2 gap-4 font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray">
            <div>
              <dt>publicado</dt>
              <dd class="mt-1 text-fg-white">{dateFormatted}</dd>
            </div>
            <div>
              <dt>duración</dt>
              <dd class="mt-1 text-fg-white">{duration}</dd>
            </div>
            <div>
              <dt>modo video</dt>
              <dd class="mt-1 text-fg-white">{videoModeLabel}</dd>
            </div>
            <div>
              <dt>explícito</dt>
              <dd class="mt-1 text-fg-white">{explicit ? 'Sí' : 'No'}</dd>
            </div>
          </dl>

          <div class="rounded-sm border border-white/10 bg-fg-black/50 px-4 py-4">
            <p class="font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray">visualizer v1</p>
            <p class="mt-3 text-sm leading-relaxed text-fg-gray">
              Este episodio se concibe como un videopodcast 16:9 con waveform, capítulos, lower thirds y branding de pilar para YouTube.
            </p>
          </div>
        </div>
      </aside>
    </header>

    <section class="mt-xl grid gap-10 lg:grid-cols-[minmax(0,1.15fr)_360px]">
      <div>
        <div class="aspect-video overflow-hidden border border-white/10 bg-black/50 shadow-[0_0_80px_rgba(0,229,255,0.08)]">
          <iframe
            class="h-full w-full"
            src={`https://www.youtube.com/embed/${youtubeVideoId}`}
            title={`${title} - Videopodcast`}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>

        <div class="mt-lg overflow-hidden border border-white/10 bg-fg-surface/20 px-5 py-5">
          <div class="flex flex-wrap items-center justify-between gap-3 border-b border-white/10 pb-4">
            <div>
              <p class="font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray">audio master</p>
              <p class="mt-1 text-sm text-fg-gray">Feed RSS, web y plataformas de podcast</p>
            </div>
            <span class="font-data text-[10px] uppercase tracking-[0.24em] text-fg-cyan">{duration}</span>
          </div>
          <audio class="mt-5 w-full" controls preload="none" src={audioUrl}>
            Tu navegador no soporta el reproductor de audio.
          </audio>
        </div>

        <div class="mt-xl">
          <p class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-gray">show notes</p>
          <FrequencyLine class="mt-4" />
          <div class="prose mt-8">
            <slot />
          </div>
        </div>
      </div>

      <aside class="space-y-6">
        <div class="border border-white/10 bg-white/[0.03] px-6 py-6">
          <p class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-gray">package del episodio</p>
          <ul class="mt-5 space-y-3 text-sm leading-relaxed text-fg-gray">
            <li>audio master listo para RSS</li>
            <li>videopodcast largo para YouTube</li>
            <li>chapters, CTA y metadata SEO</li>
            <li>2-3 clips derivados para Shorts, Reels y TikTok</li>
          </ul>
        </div>

        <div class="border border-white/10 bg-white/[0.03] px-6 py-6">
          <p class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-gray">señal pública</p>
          <ul class="mt-5 space-y-3 text-sm leading-relaxed text-fg-gray">
            <li>
              <a href="/podcast" class="text-fg-cyan hover:text-fg-white">archivo del podcast</a>
            </li>
            <li>
              <a href="/podcast/rss.xml" class="text-fg-cyan hover:text-fg-white">feed RSS del podcast</a>
            </li>
            <li>
              <a href="/contenido" class="text-fg-cyan hover:text-fg-white">archivo editorial completo</a>
            </li>
          </ul>
        </div>
      </aside>
    </section>
  </article>
</BaseLayout>
