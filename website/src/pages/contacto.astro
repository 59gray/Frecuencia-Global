---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import EditorialPageShell from '../components/EditorialPageShell.astro';
import FrequencyLine from '../components/FrequencyLine.astro';
---

<BaseLayout title="Contacto — Frecuencia Global" description="Contacta a Frecuencia Global. Correo oficial: contacto@frecuenciaglobal.org. Colaboraciones, prensa y consultas editoriales.">
  <EditorialPageShell texture="close">
  <section class="max-w-3xl mx-auto px-fg-md lg:px-fg-xl py-fg-3xl">
    <p class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-cyan mb-2 text-center">Señal abierta</p>
    <h1 class="font-display text-4xl sm:text-5xl tracking-wide text-fg-white mb-fg-md text-center">Contacto</h1>
    <p class="font-body text-fg-gray text-center mb-fg-lg max-w-xl mx-auto">
      Frecuencia Global es un proyecto editorial dedicado al análisis internacional con perspectiva contemporánea.
      Colaboraciones, prensa, ideas o consultas — abrimos frecuencia.
    </p>

    <div class="fg-tactical-panel fg-corner-cut mb-fg-xl p-6 text-center">
      <p class="font-data text-xs uppercase tracking-widest text-fg-gray mb-2">Correo oficial del proyecto</p>
      <a href="mailto:contacto@frecuenciaglobal.org" class="text-xl sm:text-2xl font-semibold text-fg-cyan hover:underline">
        contacto@frecuenciaglobal.org
      </a>
      <p class="mt-2 font-body text-sm text-fg-gray">Respuesta tipica: 24-48 horas habiles</p>
    </div>

    <FrequencyLine />

    <div class="mt-fg-xl">
      <p class="font-data text-xs uppercase tracking-widest text-fg-gray mb-fg-md text-center">O usa el formulario</p>
      <ContactForm />
    </div>

    <div class="mt-fg-3xl text-center">
      <p class="font-data text-xs tracking-widest text-fg-gray mb-fg-sm">TAMBIÉN NOS ENCUENTRAS EN</p>
      <div class="flex flex-wrap justify-center gap-2">
        <a href="https://instagram.com/globalfrequency.es" target="_blank" rel="noopener noreferrer" class="fg-corner-cut border border-white/15 px-3 py-1 font-data text-xs uppercase tracking-[0.18em] text-fg-gray transition-colors hover:border-fg-cyan/60 hover:text-fg-cyan">Instagram</a>
        <a href="https://youtube.com/@FrecuenciaGlobal" target="_blank" rel="noopener noreferrer" class="fg-corner-cut border border-white/15 px-3 py-1 font-data text-xs uppercase tracking-[0.18em] text-fg-gray transition-colors hover:border-fg-cyan/60 hover:text-fg-cyan">YouTube</a>
        <a href="https://tiktok.com/@frecuenciaglobal" target="_blank" rel="noopener noreferrer" class="fg-corner-cut border border-white/15 px-3 py-1 font-data text-xs uppercase tracking-[0.18em] text-fg-gray transition-colors hover:border-fg-cyan/60 hover:text-fg-cyan">TikTok</a>
        <a href="https://x.com/frec_global" target="_blank" rel="noopener noreferrer" class="fg-corner-cut border border-white/15 px-3 py-1 font-data text-xs uppercase tracking-[0.18em] text-fg-gray transition-colors hover:border-fg-cyan/60 hover:text-fg-cyan">X</a>
        <a href="https://www.linkedin.com/company/frecuencia-global" target="_blank" rel="noopener noreferrer" class="fg-corner-cut border border-white/15 px-3 py-1 font-data text-xs uppercase tracking-[0.18em] text-fg-gray transition-colors hover:border-fg-cyan/60 hover:text-fg-cyan">LinkedIn</a>
        <a href="https://threads.net/@globalfrequency.es" target="_blank" rel="noopener noreferrer" class="fg-corner-cut border border-white/15 px-3 py-1 font-data text-xs uppercase tracking-[0.18em] text-fg-gray transition-colors hover:border-fg-cyan/60 hover:text-fg-cyan">Threads</a>
      </div>
    </div>
  </section>
  </EditorialPageShell>
</BaseLayout>
