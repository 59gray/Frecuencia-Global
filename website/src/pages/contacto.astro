---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import FrequencyLine from '../components/FrequencyLine.astro';
---

<BaseLayout title="Contacto — Frecuencia Global" description="Contacta a Frecuencia Global. Correo oficial: contacto@frecuenciaglobal.org. Colaboraciones, prensa y consultas editoriales.">
  <section class="max-w-3xl mx-auto px-md lg:px-xl py-3xl">
    <h1 class="font-display text-5xl sm:text-6xl tracking-wider text-fg-white mb-md text-center">CONTACTO</h1>
    <p class="font-body text-fg-gray text-center mb-lg max-w-xl mx-auto">
      Frecuencia Global es un proyecto editorial dedicado al análisis internacional con perspectiva contemporánea.
      Colaboraciones, prensa, ideas o consultas — abrimos frecuencia.
    </p>

    <div class="border border-fg-cyan/30 bg-fg-cyan/5 p-6 mb-xl text-center">
      <p class="font-data text-xs uppercase tracking-widest text-fg-gray mb-2">Correo oficial del proyecto</p>
      <a href="mailto:contacto@frecuenciaglobal.org" class="font-display text-xl sm:text-2xl text-fg-cyan hover:underline tracking-wider">
        contacto@frecuenciaglobal.org
      </a>
      <p class="font-body text-sm text-fg-gray-400 mt-2">Respuesta típica: 24-48 horas hábiles</p>
    </div>

    <FrequencyLine />

    <div class="mt-xl">
      <p class="font-data text-xs uppercase tracking-widest text-fg-gray mb-md text-center">O usa el formulario</p>
      <ContactForm />
    </div>

    <div class="mt-3xl text-center">
      <p class="font-data text-xs tracking-widest text-fg-gray mb-sm">TAMBIÉN NOS ENCUENTRAS EN</p>
      <div class="flex justify-center gap-md flex-wrap">
        <a href="https://instagram.com/globalfrequency.es" target="_blank" rel="noopener noreferrer" class="font-data text-sm text-fg-gray hover:text-fg-cyan transition-colors">Instagram</a>
        <a href="https://youtube.com/@FrecuenciaGlobal" target="_blank" rel="noopener noreferrer" class="font-data text-sm text-fg-gray hover:text-fg-cyan transition-colors">YouTube</a>
        <a href="https://tiktok.com/@frecuenciaglobal" target="_blank" rel="noopener noreferrer" class="font-data text-sm text-fg-gray hover:text-fg-cyan transition-colors">TikTok</a>
        <a href="https://x.com/frec_global" target="_blank" rel="noopener noreferrer" class="font-data text-sm text-fg-gray hover:text-fg-cyan transition-colors">X</a>
        <a href="https://www.linkedin.com/company/frecuencia-global" target="_blank" rel="noopener noreferrer" class="font-data text-sm text-fg-gray hover:text-fg-cyan transition-colors">LinkedIn</a>
        <a href="https://threads.net/@globalfrequency.es" target="_blank" rel="noopener noreferrer" class="font-data text-sm text-fg-gray hover:text-fg-cyan transition-colors">Threads</a>
      </div>
    </div>
  </section>
</BaseLayout>
