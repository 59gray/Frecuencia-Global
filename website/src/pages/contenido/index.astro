---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import EditorialPageShell from '../../components/EditorialPageShell.astro';
import FrequencyLine from '../../components/FrequencyLine.astro';
import { getCollection } from 'astro:content';
import { PILLARS } from '../../lib/pillars';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pilars = ['all', 'p1', 'p2', 'p3', 'p4'] as const;
const pilarLabels: Record<string, string> = {
  all: 'TODOS',
  ...Object.fromEntries(PILLARS.map((p) => [p.id, p.titleEs.toUpperCase()])),
};
---

<BaseLayout title="Contenido — Frecuencia Global" description="Archivo del medio: piezas por pilar (Geopolitik Drop, Bass & Borders, Frecuencia Global y Behind the Policy).">
  <EditorialPageShell density="standard">
  <section class="fg-content-zone fg-fallout-matrix max-w-7xl mx-auto px-fg-md lg:px-fg-xl py-fg-3xl">
    <div class="pointer-events-none absolute inset-0 opacity-[0.06]" aria-hidden="true">
      <img src="/images/sections/fg-section-archive.png" alt="" class="h-full w-full object-cover mix-blend-screen" loading="lazy" />
    </div>

    <p class="fg-content-kicker font-data text-[11px] uppercase tracking-[0.3em] mb-2">Archivo editorial</p>
    <h1 class="font-display text-4xl sm:text-5xl text-fg-white mb-fg-md tracking-wide">Contenido</h1>
    <p class="font-body text-fg-gray mb-fg-xl max-w-2xl leading-relaxed">
      Archivo completo del sitio. Cada frecuencia agrupa piezas según su enfoque — ver{' '}
      <a href="/pilares" class="text-fg-green hover:text-fg-white underline-offset-2">las cuatro frecuencias</a>.
    </p>

    <!-- Filters -->
    <div class="flex flex-wrap gap-2 sm:gap-fg-sm mb-fg-xl" id="pilar-filters">
      {pilars.map((p) => (
        <button
          type="button"
          data-pilar={p}
          class:list={[
            'max-w-full break-words text-left font-data text-[10px] tracking-[0.12em] px-3 py-2 sm:text-xs sm:tracking-widest sm:px-fg-md sm:py-fg-xs border rounded-sm transition-colors cursor-pointer pilar-filter leading-snug',
            p === 'all' ? 'is-active' : '',
          ]}
        >
          {pilarLabels[p]}
        </button>
      ))}
    </div>

    <FrequencyLine />

    <!-- Articles grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-fg-lg mt-fg-xl" id="articles-grid">
      {sorted.map((article) => (
        <div data-pilar={article.data.pilar} class="article-item">
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            date={article.data.date}
            pilar={article.data.pilar}
            slug={article.id}
            image={article.data.cardImage ?? article.data.image}
          />
        </div>
      ))}
    </div>

    {sorted.length === 0 && (
      <div class="text-center py-fg-3xl">
        <p class="font-data text-sm tracking-widest text-fg-gray">No hay articulos publicados todavia.</p>
      </div>
    )}
  </section>
  </EditorialPageShell>
</BaseLayout>

<script>
  const filters = document.querySelectorAll('.pilar-filter');
  const items = document.querySelectorAll('.article-item');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const pilar = (btn as HTMLElement).dataset.pilar;

      // Update active filter
      filters.forEach((f) => {
        f.classList.remove('is-active');
      });
      btn.classList.add('is-active');

      // Filter articles
      items.forEach((item) => {
        const el = item as HTMLElement;
        if (pilar === 'all' || el.dataset.pilar === pilar) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });
</script>
