---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import EditorialPageShell from '../../components/EditorialPageShell.astro';
import FrequencyLine from '../../components/FrequencyLine.astro';
import SignalNode from '../../components/SignalNode.astro';
import { getCollection } from 'astro:content';
import { PILLARS, getPillarBySlug, pillarPageTitle, type PillarId } from '../../lib/pillars';

const signalColor: Record<PillarId, string> = {
  p1: 'var(--color-pilar-p1)',
  p2: 'var(--color-pilar-p2)',
  p3: 'var(--color-pilar-p3)',
  p4: 'var(--color-pilar-p4)',
};

const textClass: Record<PillarId, string> = {
  p1: 'text-pilar-p1',
  p2: 'text-pilar-p2',
  p3: 'text-pilar-p3',
  p4: 'text-pilar-p4',
};

export function getStaticPaths() {
  return PILLARS.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const pillarDef = slug ? getPillarBySlug(slug) : undefined;

if (!pillarDef) {
  return Astro.redirect('/pilares');
}

const articles = await getCollection(
  'articles',
  ({ data }) => !data.draft && data.pilar === pillarDef.id,
);

const sorted = articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pageTitle = pillarPageTitle(pillarDef);
const color = signalColor[pillarDef.id];
const titleClass = textClass[pillarDef.id];
const metaDescription =
  pillarDef.description.length > 155 ? `${pillarDef.description.slice(0, 152)}...` : pillarDef.description;
const isBassBorders = pillarDef.id === 'p2';

const formatCardDate = (date: Date) =>
  date.toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'short',
    day: '2-digit',
  });

const bassBordersMeta: Record<string, { label: string; supportLine: string; city: string; note: string }> = {
  'techno-detroit-historia-musica-electronica': {
    label: 'Matriz material',
    city: 'Detroit',
    supportLine: 'Ciudad-fábrica, memoria negra, circuito y máquina.',
    note: 'El techno no entra aquí como mito retroactivo, sino como forma nacida de una ciudad que todavía carga su propia infraestructura.',
  },
  'berghain-reglas-no-fotos': {
    label: 'Dispositivo social',
    city: 'Berlín',
    supportLine: 'Filtro, anonimato, prestigio y control de la imagen.',
    note: 'El club importa menos como icono que como tecnología informal de acceso, reputación y selección.',
  },
};
---

<BaseLayout
  title={`${pageTitle} - Frecuencia Global`}
  description={metaDescription}
  pilar={pillarDef.id}
  image={`/images/og/fg_og_pilar_${pillarDef.id}.png`}
>
  <EditorialPageShell density="standard">
    <section class="max-w-7xl mx-auto px-fg-md lg:px-fg-xl py-fg-3xl">
      <p class:list={['font-data text-[11px] uppercase tracking-[0.3em] mb-2', titleClass, 'opacity-95']}>
        Frecuencia de lectura
      </p>

      <div class="flex flex-wrap items-center gap-fg-sm mb-fg-sm">
        <SignalNode color={color} size="lg" />
        <h1 class:list={['font-display text-3xl sm:text-4xl md:text-5xl tracking-wide', titleClass]}>{pageTitle}</h1>
      </div>

      <p class:list={['font-data text-[11px] uppercase tracking-[0.22em] mb-fg-xl', titleClass, 'opacity-90']}>
        {pillarDef.subtitleEs}
      </p>

      <p class="font-body text-fg-gray max-w-3xl leading-relaxed mb-fg-xl">{pillarDef.description}</p>

      <FrequencyLine color={color} />

      {sorted.length > 0 ? (
        isBassBorders ? (
          <div class="mt-fg-xl space-y-fg-xl">
            <section class="relative overflow-hidden border-y border-white/10 px-5 py-12 sm:px-7 sm:py-14 lg:px-10">
              <div
                class="pointer-events-none absolute inset-0 opacity-70"
                style="background: radial-gradient(circle at 18% 0%, rgba(0, 229, 255, 0.13), transparent 34%), radial-gradient(circle at 82% 18%, rgba(255, 43, 214, 0.1), transparent 32%), linear-gradient(180deg, rgba(255, 255, 255, 0.018), transparent 52%);"
                aria-hidden="true"
              ></div>

              <div class="relative grid gap-12 lg:grid-cols-[minmax(0,1.2fr)_minmax(340px,0.8fr)] lg:gap-20">
                <div class="max-w-[720px]">
                  <p class="font-data text-[11px] uppercase tracking-[0.32em] text-pilar-p2/95">
                    DOSSIER BASS & BORDERS
                  </p>
                  <h2 class="mt-5 max-w-[760px] text-3xl font-semibold leading-[1.12] text-fg-white sm:text-[2.75rem] lg:text-[3.2rem]">
                    Detroit fabrica el pulso. Berghain administra la puerta.
                  </h2>
                  <p class="mt-7 text-[15px] leading-relaxed text-fg-gray sm:text-base">
                    Este dossier no compara dos ciudades de club. Lee dos formas de poder nocturno: Detroit convierte fábrica, radio y memoria negra en una señal nueva; Berghain convierte puerta, silencio y selección en autoridad cultural.
                  </p>
                  <p class="mt-4 text-[15px] leading-relaxed text-fg-gray sm:text-base">
                    La pregunta no es cuál escena “importa más”. La pregunta es qué hace cada escena con la música: una produce origen; la otra administra acceso.
                  </p>
                </div>

                <div class="flex flex-col divide-y divide-white/10 border border-white/10 bg-black/18 p-6 shadow-[0_0_60px_rgba(0,229,255,0.05)] sm:p-7 lg:p-8">
                  <div class="pb-6">
                    <p class="font-data text-[10px] uppercase tracking-[0.24em] text-pilar-p2/95">
                      QUÉ UNE ESTAS PIEZAS
                    </p>
                    <p class="mt-2 text-sm leading-relaxed text-fg-white/88">
                      La música electrónica aparece como tecnología social: organiza cuerpos, reputación, archivo y territorio.
                    </p>
                  </div>

                  <div class="py-6">
                    <p class="font-data text-[10px] uppercase tracking-[0.24em] text-pilar-p2/95">TENSIÓN CENTRAL</p>
                    <p class="mt-2 text-sm leading-relaxed text-fg-white/88">
                      Detroit funciona como raíz productiva: máquina, transmisión, comunidad y futuro negro.
                      Berghain funciona como umbral: fila, anonimato, puerta y legitimidad.
                    </p>
                  </div>

                  <div class="pt-6">
                    <p class="font-data text-[10px] uppercase tracking-[0.24em] text-pilar-p2/95">CÓMO LEERLO</p>
                    <p class="mt-2 text-sm leading-relaxed text-fg-white/88">
                      Detroit explica de dónde sale la señal.
                      Berghain muestra quién puede atravesarla.
                    </p>
                  </div>
                </div>
              </div>
            </section>

            <div class="relative min-h-[320px] overflow-hidden border border-white/12 bg-[#05070c] shadow-[0_0_80px_rgba(0,229,255,0.08)]">
              <div class="absolute inset-0 flex items-center justify-center bg-black/20">
                <img 
                  src="/images/dossiers/bass-borders-detroit-berghain-dossier.png"
                  alt="Bass & Borders: Detroit y Berghain como dualidad del poder electrónico"
                  class="w-full h-full object-cover"
                  onerror="this.style.display='none'"
                />
              </div>
              <div
                class="pointer-events-none absolute inset-0"
                style="background: radial-gradient(circle at 18% 50%, rgba(0, 229, 255, 0.18), transparent 26%), radial-gradient(circle at 82% 45%, rgba(255, 43, 214, 0.15), transparent 24%), linear-gradient(90deg, rgba(0, 229, 255, 0.08), rgba(255, 216, 107, 0.035) 50%, rgba(255, 43, 214, 0.08));"
                aria-hidden="true"
              ></div>
              <svg
                class="absolute inset-0 h-full w-full"
                viewBox="0 0 1200 360"
                preserveAspectRatio="none"
                role="img"
                aria-labelledby="bassBordersVisualTitle bassBordersVisualDesc"
              >
                <title id="bassBordersVisualTitle">Mapa visual Detroit Berghain</title>
                <desc id="bassBordersVisualDesc">Panel abstracto con señal industrial a la izquierda, frecuencia al centro y umbral de acceso a la derecha.</desc>
                <defs>
                  <linearGradient id="bassBordersSignal" x1="0" x2="1" y1="0" y2="0">
                    <stop offset="0%" stop-color="#00e5ff" stop-opacity="0.82" />
                    <stop offset="50%" stop-color="#ffd86b" stop-opacity="0.72" />
                    <stop offset="100%" stop-color="#ff2bd6" stop-opacity="0.76" />
                  </linearGradient>
                  <filter id="bassBordersGlow">
                    <feGaussianBlur stdDeviation="3" result="blur" />
                    <feMerge>
                      <feMergeNode in="blur" />
                      <feMergeNode in="SourceGraphic" />
                    </feMerge>
                  </filter>
                  <pattern id="bassBordersGrid" width="44" height="44" patternUnits="userSpaceOnUse">
                    <path d="M 44 0 L 0 0 0 44" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
                  </pattern>
                </defs>

                <rect width="1200" height="360" fill="url(#bassBordersGrid)" opacity="0.65" />
                <path d="M0 262 C120 236 192 302 284 254 S456 116 560 178 706 262 812 214 996 94 1200 124" fill="none" stroke="url(#bassBordersSignal)" stroke-width="3" filter="url(#bassBordersGlow)" />
                <path d="M0 286 C180 252 236 324 354 276 S524 146 612 202 746 290 864 238 1032 126 1200 158" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1" stroke-dasharray="6 12" />

                <g opacity="0.9">
                  <rect x="84" y="188" width="150" height="94" fill="rgba(0,229,255,0.08)" stroke="rgba(0,229,255,0.46)" />
                  <rect x="110" y="152" width="36" height="130" fill="rgba(0,229,255,0.08)" stroke="rgba(0,229,255,0.36)" />
                  <rect x="160" y="124" width="42" height="158" fill="rgba(0,229,255,0.07)" stroke="rgba(0,229,255,0.34)" />
                  <path d="M101 152 V98 M178 124 V72" stroke="rgba(255,216,107,0.65)" stroke-width="3" />
                  <circle cx="101" cy="92" r="6" fill="#ffd86b" />
                  <circle cx="178" cy="66" r="6" fill="#ffd86b" />
                  <path d="M72 98 C112 64 164 56 212 84" fill="none" stroke="rgba(0,229,255,0.48)" stroke-width="2" />
                  <path d="M54 76 C120 20 198 18 260 66" fill="none" stroke="rgba(0,229,255,0.24)" stroke-width="2" />
                </g>

                <g filter="url(#bassBordersGlow)">
                  <circle cx="384" cy="243" r="7" fill="#00e5ff" />
                  <circle cx="574" cy="184" r="6" fill="#ffd86b" />
                  <circle cx="788" cy="224" r="7" fill="#ff2bd6" />
                </g>

                <g opacity="0.92">
                  <rect x="950" y="86" width="132" height="208" fill="rgba(255,43,214,0.08)" stroke="rgba(255,43,214,0.52)" />
                  <rect x="982" y="122" width="68" height="172" fill="rgba(5,7,12,0.75)" stroke="rgba(255,216,107,0.5)" />
                  <path d="M982 122 H1050" stroke="rgba(255,43,214,0.6)" stroke-width="6" />
                  <path d="M904 122 H940 M904 178 H940 M904 234 H940" stroke="rgba(255,255,255,0.18)" stroke-width="2" />
                  <path d="M1092 142 H1154 M1092 198 H1154 M1092 254 H1154" stroke="rgba(255,255,255,0.18)" stroke-width="2" />
                </g>
              </svg>

              <div class="relative z-10 flex min-h-[320px] items-end justify-between gap-4 p-6 sm:p-8">
                <div class="max-w-[220px] border-l border-cyan-300/45 pl-4">
                  <p class="font-data text-[10px] uppercase tracking-[0.28em] text-cyan-200/90">Origen</p>
                  <p class="mt-2 text-xs leading-relaxed text-fg-gray/82">fábrica, radio, señal, memoria</p>
                </div>
                <div class="max-w-[220px] border-r border-fuchsia-300/45 pr-4 text-right">
                  <p class="font-data text-[10px] uppercase tracking-[0.28em] text-fuchsia-200/90">Umbral</p>
                  <p class="mt-2 text-xs leading-relaxed text-fg-gray/82">puerta, filtro, acceso, autoridad</p>
                </div>
              </div>
            </div>

            <div class="grid grid-cols-1 gap-fg-lg xl:grid-cols-2">
              {sorted.map((article) => {
                const meta = bassBordersMeta[article.id] ?? {
                  label: 'Señal activa',
                  city: 'Bass & Borders',
                  supportLine: 'Pieza dentro del radar.',
                  note: 'Lectura en curso dentro de esta frecuencia.',
                };

                return (
                  <article class="group fg-tactical-panel fg-corner-cut relative flex h-full flex-col overflow-hidden px-5 py-6 sm:px-6 sm:py-7">
                    <div
                      class="pointer-events-none absolute inset-0 opacity-60"
                      style="background: radial-gradient(circle at top left, rgba(124, 114, 143, 0.12), transparent 34%), linear-gradient(180deg, rgba(255, 255, 255, 0.016), transparent 50%);"
                      aria-hidden="true"
                    ></div>

                    <div class="relative flex items-center justify-between gap-3">
                      <div>
                        <p class="font-data text-[10px] uppercase tracking-[0.24em] text-pilar-p2/92">{meta.label}</p>
                        <p class="mt-2 font-data text-[10px] uppercase tracking-[0.22em] text-fg-gray/80">{meta.city}</p>
                      </div>

                      <time
                        class="font-data text-[10px] uppercase tracking-[0.22em] text-fg-gray"
                        datetime={article.data.date.toISOString()}
                      >
                        {formatCardDate(article.data.date)}
                      </time>
                    </div>

                    <a
                      href={`/contenido/${article.id}`}
                      class="fg-corner-cut relative mt-5 block aspect-[2.2/1] overflow-hidden border border-white/12 bg-fg-surface/35"
                    >
                      <img
                        src={article.data.cardImage ?? article.data.image}
                        alt={article.data.title}
                        class="h-full w-full object-cover transition-[transform,opacity] duration-300 group-hover:scale-[1.02] group-hover:opacity-95"
                        loading="lazy"
                      />
                      <div class="pointer-events-none absolute inset-0 border border-white/8" aria-hidden="true"></div>
                    </a>

                    <p class="relative mt-5 font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray/82">
                      {meta.supportLine}
                    </p>

                    <a href={`/contenido/${article.id}`} class="relative mt-4 block">
                      <h3 class="text-2xl font-semibold leading-tight text-fg-white transition-colors duration-300 group-hover:text-pilar-p2 sm:text-[1.95rem]">
                        {article.data.title}
                      </h3>
                    </a>

                    <p class="relative mt-3 text-sm leading-relaxed text-fg-gray/92 sm:text-[15px]">
                      {article.data.description}
                    </p>

                    <p class="relative mt-4 border-t border-white/10 pt-4 text-xs leading-relaxed text-fg-gray/84 sm:text-[13px]">
                      {meta.note}
                    </p>

                    <span class="relative mt-5 inline-flex items-center gap-2 font-data text-[10px] uppercase tracking-[0.22em] text-pilar-p2/95">
                      <span>LEER SEÑAL</span>
                      <span aria-hidden="true">→</span>
                    </span>
                  </article>
                );
              })}
            </div>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-fg-lg mt-fg-xl">
            {sorted.map((article) => (
              <ArticleCard
                title={article.data.title}
                description={article.data.description}
                date={article.data.date}
                pilar={article.data.pilar}
                slug={article.id}
                image={article.data.cardImage ?? article.data.image}
              />
            ))}
          </div>
        )
      ) : (
        <div class="mt-fg-xl text-center py-fg-3xl">
          <p class="font-data text-sm tracking-widest text-fg-gray">[SIN SEÑAL - PROXIMAMENTE]</p>
          <p class="font-body text-fg-gray mt-fg-sm max-w-md mx-auto">
            Aún no hay señales publicadas en esta frecuencia. Vuelve a frecuencias para explorar el resto.
          </p>
        </div>
      )}

      <div class="mt-fg-xl">
        <a href="/pilares" class="font-data text-xs tracking-widest text-fg-gray hover:text-fg-cyan transition-colors">
          ← TODAS LAS FRECUENCIAS
        </a>
      </div>
    </section>
  </EditorialPageShell>
</BaseLayout>
