---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import EditorialPageShell from '../../components/EditorialPageShell.astro';
import FrequencyLine from '../../components/FrequencyLine.astro';
import SignalNode from '../../components/SignalNode.astro';
import { getCollection } from 'astro:content';
import { PILLARS, getPillarBySlug, pillarPageTitle, type PillarId } from '../../lib/pillars';

const signalColor: Record<PillarId, string> = {
  p1: 'var(--color-pilar-p1)',
  p2: 'var(--color-pilar-p2)',
  p3: 'var(--color-pilar-p3)',
  p4: 'var(--color-pilar-p4)',
};

const textClass: Record<PillarId, string> = {
  p1: 'text-pilar-p1',
  p2: 'text-pilar-p2',
  p3: 'text-pilar-p3',
  p4: 'text-pilar-p4',
};

export function getStaticPaths() {
  return PILLARS.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const pillarDef = slug ? getPillarBySlug(slug) : undefined;

if (!pillarDef) {
  return Astro.redirect('/pilares');
}

const articles = await getCollection(
  'articles',
  ({ data }) => !data.draft && data.pilar === pillarDef.id,
);

const sorted = articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pageTitle = pillarPageTitle(pillarDef);
const color = signalColor[pillarDef.id];
const titleClass = textClass[pillarDef.id];
const metaDescription =
  pillarDef.description.length > 155 ? `${pillarDef.description.slice(0, 152)}...` : pillarDef.description;
const isBassBorders = pillarDef.id === 'p2';

const formatCardDate = (date: Date) =>
  date.toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'short',
    day: '2-digit',
  });

const bassBordersMeta: Record<string, { label: string; supportLine: string; city: string; note: string }> = {
  'techno-detroit-historia-musica-electronica.md': {
    label: 'Matriz material',
    city: 'Detroit',
    supportLine: 'Ciudad-fábrica, memoria negra, circuito y máquina.',
    note: 'El techno no entra aquí como mito retroactivo, sino como forma nacida de una ciudad que todavía carga su propia infraestructura.',
  },
  'berghain-reglas-no-fotos.md': {
    label: 'Dispositivo social',
    city: 'Berlín',
    supportLine: 'Filtro, anonimato, prestigio y control de la imagen.',
    note: 'El club importa menos como icono que como tecnología informal de acceso, reputación y selección.',
  },
  'techno-detroit-historia-musica-electronica': {
    label: 'Matriz material',
    city: 'Detroit',
    supportLine: 'Ciudad-fábrica, memoria negra, circuito y máquina.',
    note: 'El techno no entra aquí como mito retroactivo, sino como forma nacida de una ciudad que todavía carga su propia infraestructura.',
  },
  'berghain-reglas-no-fotos': {
    label: 'Dispositivo social',
    city: 'Berlín',
    supportLine: 'Filtro, anonimato, prestigio y control de la imagen.',
    note: 'El club importa menos como icono que como tecnología informal de acceso, reputación y selección.',
  },
};
---

<BaseLayout
  title={`${pageTitle} - Frecuencia Global`}
  description={metaDescription}
  pilar={pillarDef.id}
  image={`/images/og/fg_og_pilar_${pillarDef.id}.png`}
>
  <EditorialPageShell density="standard">
    <section class="max-w-7xl mx-auto px-fg-md lg:px-fg-xl py-fg-3xl">
      <p class:list={['font-data text-[11px] uppercase tracking-[0.3em] mb-2', titleClass, 'opacity-95']}>
        Pilar editorial
      </p>

      <div class="flex flex-wrap items-center gap-fg-sm mb-fg-sm">
        <SignalNode color={color} size="lg" />
        <h1 class:list={['font-display text-3xl sm:text-4xl md:text-5xl tracking-wide', titleClass]}>{pageTitle}</h1>
      </div>

      <p class:list={['font-data text-[11px] uppercase tracking-[0.22em] mb-fg-xl', titleClass, 'opacity-90']}>
        {pillarDef.subtitleEs}
      </p>

      <p class="font-body text-fg-gray max-w-3xl leading-relaxed mb-fg-xl">{pillarDef.description}</p>

      <FrequencyLine color={color} />

      {sorted.length > 0 ? (
        isBassBorders ? (
          <div class="mt-fg-xl space-y-fg-xl">
            <section class="relative overflow-hidden py-7 sm:py-9">
              <div
                class="pointer-events-none absolute inset-0"
                style="background: linear-gradient(135deg, rgba(124,114,143,0.07) 0%, transparent 55%), linear-gradient(to bottom, rgba(255,255,255,0.012), transparent 70%);"
                aria-hidden="true"
              ></div>
              <div class="pointer-events-none absolute top-0 left-0 h-px w-full" style="background: linear-gradient(90deg, var(--color-pilar-p2), transparent 60%);" aria-hidden="true"></div>
              <div class="pointer-events-none absolute bottom-0 left-0 h-px w-full opacity-30" style="background: linear-gradient(90deg, var(--color-pilar-p2), transparent 40%);" aria-hidden="true"></div>

              <div class="relative grid gap-8 lg:grid-cols-[minmax(0,1fr)_280px]">
                <div>
                  <div class="flex items-center gap-3 mb-4">
                    <span class="font-data text-[10px] uppercase tracking-[0.32em] text-pilar-p2/80">Dossier</span>
                    <span class="h-px flex-1 max-w-[40px]" style="background: var(--color-pilar-p2); opacity: 0.4;"></span>
                    <span class="font-data text-[10px] uppercase tracking-[0.32em] text-fg-gray/50">Bass & Borders</span>
                  </div>
                  <h2 class="text-2xl font-semibold leading-[1.15] text-fg-white sm:text-[1.85rem] lg:text-[2.1rem] max-w-xl">
                    Detroit fabrica el pulso.<br />
                    <em class="not-italic" style="color: var(--color-pilar-p2);">Berghain</em> administra el umbral.
                  </h2>
                  <p class="mt-4 text-[14px] leading-relaxed text-fg-gray/85 max-w-lg">
                    Bass & Borders lee la escena como mapa político: qué tipo de pertenencia produce la música,
                    qué reglas deja inscrita en el cuerpo y la ciudad.
                  </p>
                </div>

                <div class="flex flex-col gap-0 border-l border-white/8 pl-6 lg:pl-7">
                  <div class="pb-4 border-b border-white/8">
                    <span class="font-data text-[9px] uppercase tracking-[0.3em]" style="color: var(--color-pilar-p2); opacity: 0.75;">Nexo</span>
                    <p class="mt-1.5 text-[13px] leading-snug text-fg-white/75">
                      En ambas, la música ordena pertenencia antes que entretenimiento.
                    </p>
                  </div>
                  <div class="py-4 border-b border-white/8">
                    <span class="font-data text-[9px] uppercase tracking-[0.3em]" style="color: var(--color-pilar-p2); opacity: 0.75;">Tensión</span>
                    <p class="mt-1.5 text-[13px] leading-snug text-fg-white/75">
                      Detroit: raíz, máquina, memoria. <br/>Berlín: filtro, prestigio, acceso.
                    </p>
                  </div>
                  <div class="pt-4">
                    <span class="font-data text-[9px] uppercase tracking-[0.3em]" style="color: var(--color-pilar-p2); opacity: 0.75;">Radar</span>
                    <p class="mt-1.5 text-[13px] leading-snug text-fg-white/75">
                      Circuito y memoria en Detroit. <br/>Umbral y disciplina en Berghain.
                    </p>
                  </div>
                </div>
              </div>
            </section>

            <div class="grid grid-cols-1 gap-fg-lg xl:grid-cols-2">
              {sorted.map((article) => {
                const meta = bassBordersMeta[article.id] ?? {
                  label: 'Señal activa',
                  city: 'Bass & Borders',
                  supportLine: 'Pieza dentro del radar.',
                  note: 'Lectura en curso dentro del pilar.',
                };

                return (
                  <article class="group fg-tactical-panel fg-corner-cut relative flex h-full flex-col overflow-hidden px-5 py-6 sm:px-6 sm:py-7">
                    <div
                      class="pointer-events-none absolute inset-0 opacity-60"
                      style="background: radial-gradient(circle at top left, rgba(124, 114, 143, 0.12), transparent 34%), linear-gradient(180deg, rgba(255, 255, 255, 0.016), transparent 50%);"
                      aria-hidden="true"
                    ></div>

                    <div class="relative flex items-center justify-between gap-3">
                      <div>
                        <p class="font-data text-[10px] uppercase tracking-[0.24em] text-pilar-p2/92">{meta.label}</p>
                        <p class="mt-2 font-data text-[10px] uppercase tracking-[0.22em] text-fg-gray/80">{meta.city}</p>
                      </div>

                      <time
                        class="font-data text-[10px] uppercase tracking-[0.22em] text-fg-gray"
                        datetime={article.data.date.toISOString()}
                      >
                        {formatCardDate(article.data.date)}
                      </time>
                    </div>

                    <a
                      href={`/contenido/${article.id}`}
                      class="fg-corner-cut relative mt-5 block aspect-[2.2/1] overflow-hidden border border-white/12 bg-fg-surface/35"
                    >
                      <img
                        src={article.data.cardImage ?? article.data.image}
                        alt={article.data.title}
                        class="h-full w-full object-cover transition-[transform,opacity] duration-300 group-hover:scale-[1.02] group-hover:opacity-95"
                        loading="lazy"
                      />
                      <div class="pointer-events-none absolute inset-0 border border-white/8" aria-hidden="true"></div>
                    </a>

                    <p class="relative mt-5 font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray/82">
                      {meta.supportLine}
                    </p>

                    <a href={`/contenido/${article.id}`} class="relative mt-4 block">
                      <h3 class="text-2xl font-semibold leading-tight text-fg-white transition-colors duration-300 group-hover:text-pilar-p2 sm:text-[1.95rem]">
                        {article.data.title}
                      </h3>
                    </a>

                    <p class="relative mt-3 text-sm leading-relaxed text-fg-gray/92 sm:text-[15px]">
                      {article.data.description}
                    </p>

                    <p class="relative mt-4 border-t border-white/10 pt-4 text-xs leading-relaxed text-fg-gray/84 sm:text-[13px]">
                      {meta.note}
                    </p>

                    <span class="relative mt-5 inline-flex items-center gap-2 font-data text-[10px] uppercase tracking-[0.22em] text-pilar-p2/95">
                      <span>leer pieza</span>
                      <span aria-hidden="true">-&gt;</span>
                    </span>
                  </article>
                );
              })}
            </div>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-fg-lg mt-fg-xl">
            {sorted.map((article) => (
              <ArticleCard
                title={article.data.title}
                description={article.data.description}
                date={article.data.date}
                pilar={article.data.pilar}
                slug={article.id}
                image={article.data.cardImage ?? article.data.image}
              />
            ))}
          </div>
        )
      ) : (
        <div class="mt-fg-xl text-center py-fg-3xl">
          <p class="font-data text-sm tracking-widest text-fg-gray">[SIN SEÑAL - PROXIMAMENTE]</p>
          <p class="font-body text-fg-gray mt-fg-sm max-w-md mx-auto">
            Aún no hay piezas publicadas en este pilar. Vuelve a la página de pilares para ver el resto del sistema.
          </p>
        </div>
      )}

      <div class="mt-fg-xl">
        <a href="/pilares" class="font-data text-xs tracking-widest text-fg-gray hover:text-fg-cyan transition-colors">
          &lt;- TODOS LOS PILARES
        </a>
      </div>
    </section>
  </EditorialPageShell>
</BaseLayout>
