---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeFold from '../components/editorial/HomeFold.astro';
import PillarGrid from '../components/editorial/PillarGrid.astro';
import EditorialCTA from '../components/editorial/EditorialCTA.astro';
import SignalNode from '../components/SignalNode.astro';
import PillarPill from '../components/PillarPill.astro';
import { getCollection } from 'astro:content';
import { PILLARS, pillarPath } from '../lib/pillars';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allEpisodes = await getCollection('episodes', ({ data }) => !data.draft);
const sortedEpisodes = allEpisodes.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const pillars = PILLARS.map((p) => ({
  id: p.id,
  number: p.number,
  title: p.titleEs,
  subtitle: p.subtitleEs,
  description: p.description,
  href: pillarPath(p.slug),
}));

const latestArticle = sorted[0];
const latestEpisode = sortedEpisodes[0];



---

<BaseLayout
  title="Frecuencia Global"
  description="Medio editorial independiente: geopolítica, escena electrónica, tecnología y economía política del entretenimiento — cuatro frecuencias editoriales, archivo y podcast."
  image="/images/og/fg_og_default_1200x630.png"
>
  <!-- 1. HOME FOLD -->
  <HomeFold
    kicker="Editorial"
    tagline="Análisis internacional con pulso electrónico."
    title="Frecuencia Global"
    subtitle="Marca paraguas con cuatro frecuencias editoriales: cada una con su enfoque — de la geopolítica visual al análisis profesional — bajo una sola señal."
    featured={latestArticle ? {
      title: latestArticle.data.title,
      pilar: latestArticle.data.pilar,
      href: `/contenido/${latestArticle.id}`
    } : undefined}
    ctas={{
      primary: { label: 'Explorar frecuencias', href: '/pilares' },
      secondary: { label: 'Ver archivo', href: '/contenido' }
    }}
  />

  <!-- 2. ÚLTIMAS SEÑALES — grid compacto, sin imagen grande -->
  {sorted.length > 0 && (
    <section class="fg-fallout-matrix relative overflow-hidden border-b border-white/10 py-10 lg:py-14">
      <div class="pointer-events-none absolute inset-0 opacity-[0.04]" aria-hidden="true">
        <img src="/images/sections/fg-section-archive.png" alt="" class="h-full w-full object-cover mix-blend-soft-light" loading="lazy" decoding="async" />
      </div>
      <div class="relative mx-auto max-w-[1400px] px-6 lg:px-12">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-3">
            <SignalNode size="sm" />
            <p class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-cyan">Últimas señales</p>
          </div>
          <a href="/contenido" class="font-data text-[11px] uppercase tracking-[0.2em] text-fg-gray hover:text-fg-cyan transition-colors">Ver archivo →</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {sorted.slice(0, 3).map((article) => (
            <a
              href={`/contenido/${article.id}`}
              class="group fg-corner-cut flex flex-col border border-white/10 bg-black/25 p-5 transition-colors hover:border-white/20 hover:bg-black/35"
            >
              <div class="flex items-center gap-2 mb-3">
                <PillarPill pilar={article.data.pilar} size="sm" />
                <span class="font-data text-[10px] text-fg-gray/60">
                  {article.data.date.toLocaleDateString('es-MX', { day: '2-digit', month: 'short' })}
                </span>
              </div>
              <h3 class="text-base font-semibold leading-snug text-fg-white transition-colors group-hover:text-fg-cyan mb-2">
                {article.data.title}
              </h3>
              <p class="text-sm text-fg-gray/80 line-clamp-2 leading-relaxed flex-1">
                {article.data.description}
              </p>
              <span class="mt-3 font-data text-xs uppercase tracking-[0.15em] text-fg-cyan">Leer →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 3. CUATRO FRECUENCIAS -->
  <PillarGrid pillars={pillars} />

  <!-- 4. PODCAST — tarjeta compacta -->
  {latestEpisode && (
    <section class="fg-fallout-matrix relative border-t border-white/10 py-10 lg:py-14">
      <div class="relative mx-auto max-w-[1400px] px-6 lg:px-12">
        <div class="flex items-center gap-3 mb-5">
          <SignalNode size="sm" />
          <span class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-cyan">Podcast</span>
        </div>
        <div class="fg-corner-cut border border-white/12 bg-black/25 p-6 lg:p-8 max-w-3xl">
          <div class="flex items-center gap-2 mb-3">
            <PillarPill pilar={latestEpisode.data.pilar} size="sm" />
            <span class="font-data text-[10px] uppercase tracking-[0.24em] text-fg-gray">
              EP{String(latestEpisode.data.episodeNumber).padStart(2, '0')}
            </span>
          </div>
          <h3 class="text-xl font-semibold text-fg-white mb-2">{latestEpisode.data.title}</h3>
          <p class="text-sm text-fg-gray/85 mb-5 max-w-xl leading-relaxed">{latestEpisode.data.description}</p>
          <div class="flex flex-wrap gap-3">
            <a href={`/podcast/${latestEpisode.id}`} class="inline-flex items-center gap-2 bg-fg-cyan px-4 py-2 font-data text-xs uppercase tracking-[0.2em] text-fg-black transition-all hover:bg-fg-white">
              Escuchar episodio →
            </a>
            <a href="/podcast" class="inline-flex items-center gap-2 border border-white/20 px-4 py-2 font-data text-xs uppercase tracking-[0.2em] text-fg-white transition-all hover:border-fg-cyan hover:text-fg-cyan">
              Todos los episodios
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- 5. CTA FINAL -->
  <EditorialCTA
    label="Transmisión continua"
    title="La señal se construye en cada frecuencia."
    description="Podcast, archivo y piezas largas bajo la misma señal editorial."
    primaryAction={{ label: 'Contactar', href: '/contacto' }}
    secondaryAction={{ label: 'Sobre el proyecto', href: '/sobre' }}
  />
</BaseLayout>
