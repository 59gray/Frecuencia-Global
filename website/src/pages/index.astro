---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeFold from '../components/editorial/HomeFold.astro';
import PillarGrid from '../components/editorial/PillarGrid.astro';
import SignalNode from '../components/SignalNode.astro';
import PillarPill from '../components/PillarPill.astro';
import { getCollection } from 'astro:content';
import { PILLARS, pillarPath } from '../lib/pillars';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pillars = PILLARS.map((p) => ({
  id: p.id,
  number: p.number,
  title: p.titleEs,
  subtitle: p.subtitleEs,
  description: p.description,
  href: pillarPath(p.slug),
}));

const latestArticle = sorted[0];
const recentArticles = latestArticle
  ? sorted.filter((a) => a.id !== latestArticle.id).slice(0, 3)
  : sorted.slice(0, 3);


---

<BaseLayout
  title="Frecuencia Global"
  description="Análisis internacional independiente: geopolítica, escena electrónica, tecnología y economía política del entretenimiento — cuatro frecuencias de lectura, archivo y podcast."
  image="/images/og/fg_og_default_1200x630.png"
>
  <!-- 1. HOME FOLD -->
  <HomeFold
    kicker="Radar Global"
    tagline="Geopolítica, cultura electrónica y tecnología en la misma frecuencia."
    title="Frecuencia Global"
    subtitle="Leemos conflictos, plataformas, escenas musicales y decisiones de poder como señales conectadas: análisis internacional con estética electrónica y criterio propio."
    featured={latestArticle ? {
      title: latestArticle.data.title,
      pilar: latestArticle.data.pilar,
      href: `/contenido/${latestArticle.id}`,
      image: '/images/articles/techno-detroit-featured-card.png',
      description: latestArticle.data.description
    } : undefined}
    ctas={{
      primary: { label: 'Leer señales', href: '/pilares' },
      secondary: { label: 'Ver archivo', href: '/contenido' }
    }}
  />

  <!-- 2. ÚLTIMAS SEÑALES — grid compacto, sin imagen grande -->
  {recentArticles.length > 0 && (
    <section class="fg-fallout-matrix relative overflow-hidden border-b border-white/10 py-10 lg:py-14">
      <div class="pointer-events-none absolute inset-0 opacity-[0.04]" aria-hidden="true">
        <img src="/images/sections/fg-section-archive.png" alt="" class="h-full w-full object-cover mix-blend-soft-light" loading="lazy" decoding="async" />
      </div>
      <div class="relative mx-auto max-w-[1400px] px-6 lg:px-12">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-3">
            <SignalNode size="sm" />
            <p class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-cyan">Últimas señales</p>
          </div>
          <a href="/contenido" class="font-data text-[11px] uppercase tracking-[0.2em] text-fg-gray hover:text-fg-cyan transition-colors">Ver archivo →</a>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {recentArticles.map((article) => (
            <a
              href={`/contenido/${article.id}`}
              class="group fg-corner-cut flex flex-col border border-white/10 bg-black/25 p-5 transition-all duration-200 hover:border-fg-cyan/40 hover:bg-black/40 hover:shadow-[0_0_20px_-8px_rgba(0,229,255,0.18)]"
            >
              <div class="flex items-center justify-between gap-2 mb-3">
                <PillarPill pilar={article.data.pilar} size="sm" />
                <span class="font-data text-[10px] tabular-nums text-fg-gray/50">
                  {article.data.date.toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: '2-digit' })}
                </span>
              </div>
              <h3 class="text-sm font-semibold leading-snug text-fg-white transition-colors group-hover:text-fg-cyan mb-2 sm:text-base">
                {article.data.title}
              </h3>
              <p class="text-xs text-fg-gray/70 line-clamp-2 leading-relaxed flex-1 sm:text-sm">
                {article.data.description}
              </p>
              <span class="mt-4 inline-flex items-center gap-1 font-data text-[11px] uppercase tracking-[0.15em] text-fg-cyan opacity-70 transition-opacity group-hover:opacity-100">
                Leer
                <span class="transition-transform group-hover:translate-x-0.5">→</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 3. CUATRO FRECUENCIAS -->
  <PillarGrid pillars={pillars} />

  <!-- 4. PODCAST — próximamente -->
  <section class="fg-fallout-matrix relative border-t border-white/10 py-10 lg:py-14">
    <div class="relative mx-auto max-w-[1400px] px-6 lg:px-12">
      <div class="flex items-center gap-3 mb-5">
        <SignalNode size="sm" />
        <span class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-cyan">Podcast</span>
      </div>
      <div class="fg-corner-cut border border-white/10 bg-black/20 p-6 lg:p-8 max-w-3xl flex items-center gap-6">
        <div class="shrink-0 flex items-center justify-center w-10 h-10 rounded-full border border-fg-cyan/25 text-fg-cyan/50">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
          </svg>
        </div>
        <div>
          <p class="font-data text-[10px] uppercase tracking-[0.3em] text-fg-cyan/60 mb-1">Próximamente</p>
          <p class="text-sm text-fg-gray/70 leading-relaxed max-w-lg">
            Audio-first en RSS, videopodcast con visualizer en YouTube. La señal llega pronto.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
