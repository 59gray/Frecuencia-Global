---
import BaseLayout from '../layouts/BaseLayout.astro';
import EditorialPageShell from '../components/EditorialPageShell.astro';
import FrequencyLine from '../components/FrequencyLine.astro';
import SignalNode from '../components/SignalNode.astro';
import { PILLARS, type PillarId } from '../lib/pillars';

const signalVar: Record<PillarId, string> = {
  p1: 'var(--color-pilar-p1)',
  p2: 'var(--color-pilar-p2)',
  p3: 'var(--color-pilar-p3)',
  p4: 'var(--color-pilar-p4)',
};
const titleClass: Record<PillarId, string> = {
  p1: 'text-pilar-p1',
  p2: 'text-pilar-p2',
  p3: 'text-pilar-p3',
  p4: 'text-pilar-p4',
};
---

<BaseLayout
  title="Sobre — Frecuencia Global"
  description="Medio editorial independiente dedicado al análisis internacional con pulso electrónico. Cuatro pilares, un sistema de señal."
>
  <EditorialPageShell>
  <section class="max-w-3xl mx-auto px-fg-md lg:px-fg-xl py-fg-3xl">
    <p class="font-data text-[11px] uppercase tracking-[0.3em] text-fg-cyan mb-2">Sobre el proyecto</p>
    <h1 class="text-4xl sm:text-5xl text-fg-white mb-fg-lg font-display tracking-wide">Manifiesto Editorial</h1>

    <FrequencyLine />

    <div class="space-y-fg-xl font-body text-fg-gray leading-relaxed">
      <p class="text-lg text-fg-white">
        Frecuencia Global es un <strong class="text-fg-cyan">medio editorial independiente</strong> dedicado al análisis internacional. Traducimos la complejidad geopolítica al lenguaje visual y narrativo contemporáneo.
      </p>

      <p>
        Nació de una convicción: que la geopolítica, la cultura global y la industria musical son demasiado importantes para quedar envueltas en jerga académica o titulares vacíos. Merecen un formato que respete tanto la inteligencia del lector como su tiempo.
      </p>

      <p>
        Nuestra estética bebe del lenguaje de la <strong class="text-pilar-p2">música electrónica</strong> — señal, pulso, frecuencia, capas. No es decoración festiva. Es un sistema visual de comunicación: riguroso en el contenido, contemporáneo en la forma.
      </p>

      <FrequencyLine color="var(--color-pilar-p2)" />

      <h2 class="text-2xl text-fg-white font-semibold">Sistema editorial</h2>
      <p class="text-sm text-fg-gray/95">
        Cuatro pilares con foco y tono distintos — no categorías genéricas de blog. El pilar <strong class="text-pilar-p3">Frecuencia Global</strong> comparte nombre con la marca porque concentra la síntesis y la cadencia informativa; es una frecuencia dentro del sistema.
      </p>

      <div class="space-y-fg-lg">
        {PILLARS.map((p) => (
          <div class="flex items-start gap-fg-sm">
            <SignalNode color={signalVar[p.id]} />
            <div>
              <h3 class:list={['text-lg font-semibold', titleClass[p.id]]}>{p.titleEs}</h3>
              <p class:list={['text-xs font-data uppercase tracking-[0.18em] mt-1', titleClass[p.id], 'opacity-85']}>
                {p.subtitleEs}
              </p>
              <p class="text-sm mt-2 leading-relaxed">{p.description}</p>
            </div>
          </div>
        ))}
      </div>

      <FrequencyLine color="var(--color-pilar-p3)" />

      <h2 class="text-2xl text-fg-white font-semibold">Manifiesto</h2>

      <blockquote class="border-l-2 border-fg-cyan pl-fg-md italic text-fg-white">
        "No simplificamos. Traducimos. No somos neutrales. Somos rigurosos. No competimos por atención. Competimos por comprensión."
      </blockquote>

      <p>
        Frecuencia Global opera en la intersección de periodismo, diseño y tecnología. Cada pieza es investigada, escrita y producida como un sistema coherente — no como contenido descartable.
      </p>

      <p class="font-data text-xs tracking-widest text-fg-cyan">&#x25CF; TRANSMITIENDO DESDE 2026</p>
    </div>
  </section>
  </EditorialPageShell>
</BaseLayout>
