# Frecuencia Global - Environment Variables Template
# Copiar este archivo a .env y completar con credenciales reales
# NO commitear el archivo .env al repositorio

# =============================================================================
# THREADS API (Graph API) - OPERATIVO
# =============================================================================
# App: Frecuencia Global Publisher (App ID: 1227523599160977)
# Account: @globalfrequency.es (ID: 26618714181055427)
# Permisos requeridos: threads_basic, threads_content_publish
THREADS_ACCESS_TOKEN=your_threads_access_token_here
THREADS_USER_ID=26618714181055427

# =============================================================================
# INSTAGRAM GRAPH API - PENDIENTE
# =============================================================================
# Bloqueo: Cuenta actual es personal, necesita conversión a Business/Creator
# Para usar Graph API, la cuenta debe ser:
#   - Instagram Business Account, o
#   - Instagram Creator Account
# Mientras tanto, usar browser automation (ig_publish_post.py)
INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id

# Facebook App vinculada (misma app que Threads)
FACEBOOK_APP_ID=1227523599160977
FACEBOOK_APP_SECRET=your_app_secret_here

# =============================================================================
# APIs DE TERCEROS (Image Hosting)
# =============================================================================
# Catbox.moe / Litterbox - hosting temporal de imágenes (72h)
# Usado por Threads API para publicar imágenes
CATBOX_TOKEN=optional

# =============================================================================
# PLATAFORMAS CON BROWSER AUTOMATION (No requieren tokens API)
# =============================================================================
# X/Twitter - Browser automation con Chrome real
# LinkedIn - Browser automation con Chrome real
# Instagram - Browser automation con Chrome real (fallback hasta Graph API)
# TikTok - Browser automation con Chrome real (STANDBY - esperando autorización)

# =============================================================================
# NOTAS DE IMPLEMENTACIÓN
# =============================================================================
# 1. Threads API usa image hosting externo (catbox.moe/litterbox) para URLs de 72h
# 2. Instagram Graph API requiere cuenta Business/Creator - no aplicable aún
# 3. Browser automation es el método principal para X, LinkedIn, Instagram
# 4. TikTok está en STANDBY esperando autorización de cuenta

# Fecha de template: 2026-04-04
