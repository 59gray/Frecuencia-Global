{
  "name": "WF-009 — Publicar en LinkedIn (Cloud)",
  "nodes": [
    {
      "id": "wf009c_trigger",
      "name": "Webhook Publish LinkedIn",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 300],
      "parameters": {
        "httpMethod": "POST",
        "path": "publish-linkedin",
        "responseMode": "responseNode",
        "options": {}
      },
      "webhookId": "publish-linkedin"
    },
    {
      "id": "wf009c_validate",
      "name": "Validar Input",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [220, 300],
      "parameters": {
        "conditions": {
          "options": {"caseSensitive": false},
          "combinator": "and",
          "conditions": [
            {
              "leftValue": "={{ $json.body.pieza }}",
