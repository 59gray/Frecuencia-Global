# =============================================================
# Frecuencia Global - Podcast env starter
# =============================================================
# Copia este archivo a .env.podcast.local o integra estos valores
# dentro de .env / .env.cloud segun el entorno donde vayas a correr.
# =============================================================

# --- Website editorial opcional ---
FG_SITE_URL=https://frecuenciaglobal.vercel.app
FG_WEBSITE_URL=https://frecuenciaglobal.vercel.app
FG_WEBSITE_PREVIEW_URL=https://website-three-rho-26.vercel.app

# --- Podcast host principal ---
FG_PODCAST_HOST=rss.com
FG_PODCAST_SLUG=frecuencia-global-podcast

# Estas dos URLs son placeholders de marca.
# Sustituyelas por las definitivas cuando el show exista en RSS.com.
FG_PODCAST_SHOW_URL=https://rss.com/podcasts/frecuencia-global-podcast
FG_PODCAST_RSS_URL=https://media.rss.com/frecuencia-global-podcast/feed.xml

# --- Opcional para pruebas n8n ---
# Usa una pieza real EP_### cuando exista
SMOKE_TEST_PIEZA=EP_001
