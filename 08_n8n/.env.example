# =============================================================
# Frecuencia Global — n8n Environment Variables
# =============================================================
# Copiar este archivo como .env y completar los valores:
#   cp .env.example .env
#
# NUNCA subir .env a Git. Ya está en .gitignore.
# =============================================================

# --- Autenticación n8n (UI web) ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=<cambiar-por-password-seguro>

# --- Zona horaria ---
TZ=America/Mexico_City

# --- Webhook base URL ---
# En local: http://localhost:5678
# Si usas tunnel (ngrok/cloudflared): https://tu-tunnel.ngrok.io
WEBHOOK_URL=http://localhost:5678

# --- Frecuencia Global web + podcast ---
# Website editorial opcional
FG_WEBSITE_URL=https://frecuenciaglobal.vercel.app
FG_WEBSITE_PREVIEW_URL=https://website-three-rho-26.vercel.app

# Host principal del podcast
FG_PODCAST_HOST=rss.com
FG_PODCAST_SLUG=frecuencia-global-podcast
FG_PODCAST_SHOW_URL=https://rss.com/podcasts/frecuencia-global-podcast
FG_PODCAST_RSS_URL=https://media.rss.com/frecuencia-global-podcast/feed.xml

# --- Telegram Bot (opcional) ---
# 1. Abrir Telegram → buscar @BotFather → /newbot
# 2. Copiar el token que te da BotFather
# 3. Enviar un mensaje al bot, luego visitar:
#    https://api.telegram.org/bot<TU_TOKEN>/getUpdates
#    para obtener tu chat_id
# REQUIERE APROBACIÓN: creación del bot en tu cuenta personal
TELEGRAM_BOT_DISPLAY_NAME=Frecuencia Global Checkpoint
TELEGRAM_BOT_USERNAME_SUGGESTED=FrecuenciaGlobalCheckpointBot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
