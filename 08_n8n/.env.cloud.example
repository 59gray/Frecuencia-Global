# =============================================================
# Frecuencia Global - n8n Cloud Deploy Config
# =============================================================
# cp .env.cloud.example .env.cloud
# Completar TODOS los valores antes de correr deploy_cloud.js
# NUNCA subir .env.cloud a Git.
# =============================================================

# --- n8n Cloud ---
N8N_BASE_URL=https://frecuenciaglobal.app.n8n.cloud
N8N_API_KEY=n8n_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- GitHub ---
GITHUB_OWNER=59gray
GITHUB_REPO=Frecuencia-Global
GITHUB_BRANCH=main
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Social publishing ---
# Bridge-based workflows should derive endpoint paths from BRIDGE_URL whenever possible.
BRIDGE_URL=

# Optional explicit override for X. If blank, deploy_cloud.js derives it from BRIDGE_URL.
X_PUBLISH_WEBHOOK_URL=

# Instagram / TikTok can keep dedicated webhook URLs until they are standardized on BRIDGE_URL.
# LinkedIn publishes directly via API and needs the author URN.
IG_PUBLISH_WEBHOOK_URL=
TIKTOK_PUBLISH_WEBHOOK_URL=
LINKEDIN_AUTHOR_URN=urn:li:organization:112349668

# --- Frecuencia Global web + podcast ---
# URL editorial opcional para enlaces y pagina de episodio
FG_SITE_URL=https://frecuenciaglobal.is-a.dev
FG_WEBSITE_URL=https://frecuenciaglobal.is-a.dev
FG_WEBSITE_PREVIEW_URL=https://website-three-rho-26.vercel.app

# Host principal del podcast en RSS.com
FG_PODCAST_HOST=rss.com
FG_PODCAST_SLUG=frecuencia-global-podcast
FG_PODCAST_SHOW_URL=https://rss.com/podcasts/frecuencia-global-podcast
FG_PODCAST_RSS_URL=https://media.rss.com/frecuencia-global-podcast/feed.xml

# --- Smoke test (pieza existente en 03_Editorial del repo) ---
# Dejar vacio para saltar smoke test en deploy
SMOKE_TEST_PIEZA=
